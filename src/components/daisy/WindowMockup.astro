---
import Hi from "./Hi.astro";
interface Props {
  image: string;
  classes: string;
}

const { classes } = Astro.props;
---

<div class=`mockup-window border bg-slate-50 ${classes}`>
  <div class="flex justify-center border-t border-base-300">
    <div class="absolute top-[50%]">
      <Hi />
    </div>
  </div>
</div>
