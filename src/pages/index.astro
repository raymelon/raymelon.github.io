  // });

  // magicGrid.listen();

  // setTimeout(() => {
  // 	magicGrid.positionItems();
  // }, 2000);

  import Muuri from "muuri";

  var dragSortOptions = {
    action: "swap",
    threshold: 50,
  };
  var grid = new Muuri(".containerCust", {
    dragEnabled: false,
    layout: {
      fillGaps: false,
      // alignRight: true,
      // alignBottom: true,
      // rounding: true,
    },
    dragStartPredicate: function (item, event) {
      // Prevent first item from being dragged.
      if (grid.getItems().indexOf(item) === 5) {
        return false;
      }
      // For other items use the default drag start predicate.
      return Muuri.ItemDrag.defaultStartPredicate(item, event);
    },
    dragSortPredicate: function (item) {
      var result = Muuri.ItemDrag.defaultSortPredicate(item, dragSortOptions);
      return result && result.index === 5 ? false : result;
    },
  });

  addEventListener("dragover", (event) => {
    console.log({ event });
  });

  addEventListener("drop", (event) => {
    console.log({ event });
  });

  addEventListener("dragend", (event) => {
    console.log({ event });
  });

  addEventListener("click", (event) => {
    console.log({ event });
  });

  const itemCustMockups = document.querySelectorAll(".itemCustMockup");

  itemCustMockups.forEach((itemCustMockup) => {
    itemCustMockup.addEventListener("mouseover", (event) => {
      localStorage.setItem("gridShuffle", "off");
      document.getElementById("gridShuffleAlertContainer").style.visibility =
        "visible";
      document.getElementById("gridShuffleAlert").textContent = "❚❚ Paused";
    });

    itemCustMockup.addEventListener("mouseleave", (event) => {
      localStorage.setItem("gridShuffle", "on");
      document.getElementById("gridShuffleAlertContainer").style.visibility =
        "visible";
      document.getElementById("gridShuffleAlert").textContent = "⏵ Resumed";
      setTimeout(() => {
        document.getElementById("gridShuffleAlertContainer").style.visibility =
          "hidden";
      }, 2500);
    });
  });

  setInterval(() => {
    // const elemA = document.createElement("div");
    // elemA.classList.add("itemCust");
    // elemA.classList.add("item14");
    // elemA.innerHTML = `<div class="relative w-[100%] h-[100%]">13</div>`;
    // grid.add([elemA], { index: 5 });

    const gridShuffle = localStorage.getItem("gridShuffle");

    if (gridShuffle === "on") {
      let randomNum = Math.floor(Math.random() * 12);
      const seed = Math.floor(Math.random() * 3);

      if (randomNum + seed > 12) {
        // randomNum = 1;
        randomNum = 0;
      }

      if (randomNum === 0) {
        // randomNum = 1;
        randomNum = 1;
      }

      grid.move(0 + randomNum, -1, { action: "move" });
      grid.synchronize();

      // switch (randomNum) {
      //   case 1:
      //     grid.sort(grid.getItems().reverse());
      //     break;
      //   case 2:
      //     grid.move(0, -1, { action: "move" });
      //     break;
      //   case 3:
      //     grid.sort(grid.getItems());
      //     break;
      //   default:
      //     grid.move(0 + randomNum, -1, { action: "move" });
      //     break;
      // }

      //

      // grid.refreshItems();
      // grid.layout();
    }
  }, 2000);
</script>

