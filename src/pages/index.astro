<style>
  body {
    /* overflow: hidden; */
    overflow-y: auto;

    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE and Edge */
  }

  body::-webkit-scrollbar {
    display: none;
  }

  #tile1 {
    opacity: 1;
    background-color: transparent;
    border: 0;
  }

  #gridShuffleAlertContainer {
    visibility: hidden;
  }

  .containerCust {
    position: relative;
  }
  .itemCust {
    position: absolute;
    width: 300px;
    height: 500px;
    background-color: rgb(250, 235, 215, 0.2);
    display: flex;
    justify-content: center;
    align-items: center;
    border: 10px solid rgb(250, 235, 215, 0);
    border-radius: 8px;
    /* color: antiquewhite; */
    z-index: 1;
    padding: 5px;
    margin: 5px;
    opacity: 0.25;
  }

  .itemCustMockup:hover {
    opacity: 1;
  }

  .itemCust.muuri-item-hidden {
    z-index: 0;
  }

  .itemCust.muuri-item-positioning {
    z-index: 2;
  }

  .itemCust.muuri-item-releasing {
    z-index: 3;
  }
  .itemCust.muuri-item-dragging {
    z-index: 4;
  }

  .containerCust .item1 {
    height: 200px;
    width: 350px;
  }
  .containerCust .item4 {
    width: 600px;
    height: 300px;
  }

  .containerCust .item5 {
