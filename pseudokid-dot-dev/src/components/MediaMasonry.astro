---
import { getPortfolioAssetUrl, isImageAsset, isVideoAsset } from '../lib/portfolio';

interface Props {
  assets: string[];
  projectName: string;
  label?: string;
  videoControls?: boolean;
  className?: string;
}

const { assets = [], projectName, label = `${projectName} media masonry`, videoControls = false, className = '' } = Astro.props;

const entries = assets.map((asset) => {
  const url = getPortfolioAssetUrl(asset);

  return {
    asset,
    url,
    type: isVideoAsset(asset) ? 'video' : isImageAsset(asset) ? 'image' : 'unknown'
  };
});
---

<div class={`media-masonry ${className}`} aria-label={label}>
  {entries.length === 0 ? (
    <div class="media-empty is-visible">No media yet</div>
  ) : (
    <div class="media-masonry-grid">
      {entries.map((entry, index) => (
        <article class="masonry-item">
          {!entry.url ? (
            <div class="media-empty is-visible">Media unavailable</div>
          ) : entry.type === 'video' ? (
            <div class="masonry-frame">
              <video
                src={entry.url}
                preload="metadata"
                playsinline
                controls={videoControls}
                muted={!videoControls}
                autoplay={!videoControls}
                loop={!videoControls}
                aria-label={`${projectName} media ${index + 1}`}
                onerror="this.hidden=true;this.nextElementSibling?.classList.add('is-visible');"
              ></video>
              <div class="media-empty">Media unavailable</div>
            </div>
          ) : entry.type === 'image' ? (
            <div class="masonry-frame">
              <img
                src={entry.url}
                alt={`${projectName} media ${index + 1}`}
                loading="lazy"
                decoding="async"
                onerror="this.hidden=true;this.nextElementSibling?.classList.add('is-visible');"
              />
              <div class="media-empty">Media unavailable</div>
            </div>
          ) : (
            <div class="media-empty is-visible">Unsupported media</div>
          )}
        </article>
      ))}
    </div>
  )}
</div>

<style>
  .media-masonry {
    width: 100%;
    height: 100%;
    min-height: 0;
    background: #000000;
  }

  .media-masonry-grid {
    column-count: 2;
    column-gap: 0.55rem;
    padding: 0.55rem;
  }

  .masonry-item {
    break-inside: avoid;
    margin: 0 0 0.55rem;
    border-radius: 0.7rem;
    overflow: hidden;
    background: #000000;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .masonry-frame,
  .media-empty {
    width: 100%;
    background: #000000;
    display: grid;
    place-items: center;
    position: relative;
  }

  .masonry-frame img,
  .masonry-frame video {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    object-position: center;
    background: #000000;
  }

  .media-empty {
    display: none;
    min-height: 5.5rem;
    text-transform: uppercase;
    font: 700 0.55rem/1.4 'Inter', sans-serif;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.74);
    border: 1px dashed rgba(255, 255, 255, 0.2);
    text-align: center;
    padding: 0.55rem;
  }

  .media-empty.is-visible {
    display: grid;
  }

  @media (max-width: 640px) {
    .media-masonry-grid {
      column-count: 1;
    }
  }
</style>
