---
---

<footer class="site-footer-embedded" aria-label="Site footer">
  <div class="footer-embedded-content">
    <div class="footer-brand-col">
      <a href="/" class="footer-brand-link">
        <div class="brand-text">
          pseudokid<span class="brand-dot">.</span>dev
        </div>
      </a>
      <div class="footer-status footer-embedded-status">
        <span class="status-dot"></span>
        <span>Available for new projects</span>
      </div>
    </div>
    <div class="footer-right-col">
      <div class="footer-links">
        <a href="https://github.com/raymelon" target="_blank" rel="noreferrer noopener"
          >GitHub</a
        >
        <a
          href="https://www.linkedin.com/in/raymelfrancisco/"
          target="_blank"
          rel="noreferrer noopener">LinkedIn</a
        >
        <a href="https://x.com/pseudokid" target="_blank" rel="noreferrer noopener"
          >X/Twitter</a
        >
        <a href="mailto:raymel@pseudokid.dev">Email</a>
      </div>
      <div class="footer-built-with">
        <span>Built with Astro</span><span class="fbw-sep">&nbsp;•&nbsp;</span><wbr/><span>Birthed with OpenCode</span><span class="fbw-sep">&nbsp;•&nbsp;</span><wbr /><span>Stitched with Stitch</span><span class="fbw-sep">&nbsp;•&nbsp;</span><wbr /><span>© 2026</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer-embedded {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 3rem 1.5rem 4rem;
  }

  @media (min-width: 761px) {
    .site-footer-embedded {
      padding: 3rem 2.5rem 4.5rem;
    }
  }

  .footer-embedded-content {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-brand-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-brand-link {
    text-decoration: none;
  }

  .footer-brand-link .brand-text {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .footer-brand-link .brand-dot {
    color: #3b82f6;
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .footer-right-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #ffff00;
  }

  .footer-built-with {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.2);
    text-align: right;
    line-height: 1.8;
    overflow-wrap: break-word;
  }

  .fbw-sep {
    display: inline;
    white-space: pre;
  }
</style>
