---
import { getPortfolioAssetUrl, isImageAsset, isVideoAsset } from '../lib/portfolio';

interface Props {
  assets: string[];
  projectName: string;
  label?: string;
  showControls?: boolean;
  videoControls?: boolean;
  autoplay?: boolean;
  autoplayIntervalMs?: number;
  forceContain?: boolean;
  className?: string;
}

const AUTOPLAY_MIN_INTERVAL_MS = 4300;
const AUTOPLAY_MAX_INTERVAL_MS = 7600;

function hashString(value: string) {
  let hash = 2166136261;

  for (let index = 0; index < value.length; index += 1) {
    hash ^= value.charCodeAt(index);
    hash = Math.imul(hash, 16777619);
  }

  return hash >>> 0;
}

function getDeterministicAutoplayInterval(projectLabel: string, mediaAssets: string[]) {
  const seed = `${projectLabel}::${mediaAssets.join('|')}`;
  const range = AUTOPLAY_MAX_INTERVAL_MS - AUTOPLAY_MIN_INTERVAL_MS;
  return AUTOPLAY_MIN_INTERVAL_MS + (hashString(seed) % (range + 1));
}

const {
  assets = [],
  projectName,
  label = `${projectName} media carousel`,
  showControls = true,
  videoControls = false,
  autoplay = true,
  autoplayIntervalMs,
  forceContain = false,
  className = ''
} = Astro.props;

const resolvedAutoplayIntervalMs = typeof autoplayIntervalMs === 'number' && Number.isFinite(autoplayIntervalMs)
  ? Math.max(2200, Math.round(autoplayIntervalMs))
  : getDeterministicAutoplayInterval(projectName, assets);

const slides = assets.map((asset) => {
  const url = getPortfolioAssetUrl(asset);

  return {
    asset,
    url,
    type: isVideoAsset(asset) ? 'video' : isImageAsset(asset) ? 'image' : 'unknown'
  };
});

const posterSlide = slides.find((slide) => slide.type === 'image' && Boolean(slide.url));
const posterUrl = posterSlide?.url ?? undefined;
---

<div
  class={`media-carousel ${className}`}
  data-carousel
  data-force-contain={forceContain ? 'true' : 'false'}
  data-autoplay={autoplay ? 'true' : 'false'}
  data-autoplay-interval={String(resolvedAutoplayIntervalMs)}
  aria-roledescription="carousel"
  aria-label={label}
>
  {slides.length === 0 ? (
    <div class="media-empty is-visible">No media yet</div>
  ) : (
    <>
      <div class="media-carousel-viewport" data-carousel-viewport tabindex={slides.length > 1 ? '0' : undefined}>
        <div class="media-carousel-track" data-carousel-track>
          {slides.map((slide, index) => (
            <div
              class="media-slide"
              data-carousel-slide
              data-active={index === 0 ? 'true' : 'false'}
              role="group"
              aria-roledescription="slide"
              aria-label={`Media ${index + 1} of ${slides.length}`}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              {!slide.url ? (
                <div class="media-empty is-visible">Media unavailable</div>
              ) : slide.type === 'video' ? (
                <div class="media-frame">
                  <video
                    src={slide.url}
                    poster={posterUrl}
                    preload="metadata"
                    playsinline
                    controls={videoControls}
                    muted={!videoControls}
                    autoplay={!videoControls}
                    loop={!videoControls}
                    aria-label={`${projectName} video ${index + 1}`}
                    data-video-slide
                    data-media-element
                    data-autoplay={!videoControls ? 'true' : 'false'}
                    onerror="this.hidden=true;this.nextElementSibling?.classList.add('is-visible');"
                  ></video>
                  <div class="media-empty">Media unavailable</div>
                </div>
              ) : slide.type === 'image' ? (
                <div class="media-frame">
                  <img
                    src={slide.url}
                    alt={`${projectName} media ${index + 1}`}
                    data-media-element
                    loading="lazy"
                    decoding="async"
                    onerror="this.hidden=true;this.nextElementSibling?.classList.add('is-visible');"
                  />
                  <div class="media-empty">Media unavailable</div>
                </div>
              ) : (
                <div class="media-empty is-visible">Unsupported media</div>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="media-tint" aria-hidden="true"></div>

      {showControls && slides.length > 1 ? (
        <div class="media-carousel-controls" aria-label={`${projectName} carousel controls`}>
          <button type="button" class="media-control" data-carousel-prev aria-label={`Previous media for ${projectName}`}>
            Prev
          </button>
          <p class="media-counter" aria-live="polite">
            <span data-carousel-current>1</span>
            <span aria-hidden="true">/</span>
            <span>{slides.length}</span>
          </p>
          <button type="button" class="media-control" data-carousel-next aria-label={`Next media for ${projectName}`}>
            Next
          </button>
        </div>
      ) : null}
    </>
  )}
</div>

<script is:inline>
  (() => {
    const initializeKey = '__portfolioInitializeCarousel';

    if (typeof window[initializeKey] !== 'function') {
      window[initializeKey] = (carousel) => {
    if (!(carousel instanceof HTMLElement) || carousel.dataset.carouselInitialized === 'true') {
      return;
    }

    const track = carousel.querySelector('[data-carousel-track]');
    const slides = Array.from(carousel.querySelectorAll('[data-carousel-slide]'));
    const prev = carousel.querySelector('[data-carousel-prev]');
    const next = carousel.querySelector('[data-carousel-next]');
    const current = carousel.querySelector('[data-carousel-current]');
    const viewport = carousel.querySelector('[data-carousel-viewport]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const autoplayEnabled = carousel.dataset.autoplay === 'true' && slides.length > 1;
    const autoplayInterval = Math.max(2200, Number.parseInt(carousel.dataset.autoplayInterval ?? '5600', 10) || 5600);
    let pageHidden = document.visibilityState === 'hidden';

    if (!track || slides.length === 0) {
      return;
    }

    carousel.dataset.carouselInitialized = 'true';

    let activeIndex = 0;
    let autoplayTimer = null;
    let resumeTimer = null;
    let pointerInside = false;
    let focusInside = false;

    const clearAutoplay = () => {
      if (autoplayTimer !== null) {
        window.clearInterval(autoplayTimer);
        autoplayTimer = null;
      }
    };

    const clearResumeTimer = () => {
      if (resumeTimer !== null) {
        window.clearTimeout(resumeTimer);
        resumeTimer = null;
      }
    };

    const canAutoplay = () => autoplayEnabled && !prefersReducedMotion.matches && !pageHidden;

    const setOrientation = (slide, width, height) => {
      if (!slide || !Number.isFinite(width) || !Number.isFinite(height) || width <= 0 || height <= 0) {
        return;
      }

      slide.dataset.orientation = height > width ? 'portrait' : 'landscape';
    };

    slides.forEach((slide) => {
      const image = slide.querySelector('img[data-media-element]');
      if (image instanceof HTMLImageElement) {
        if (image.complete) {
          setOrientation(slide, image.naturalWidth, image.naturalHeight);
        } else {
          image.addEventListener('load', () => {
            setOrientation(slide, image.naturalWidth, image.naturalHeight);
          });
        }
      }

      const video = slide.querySelector('video[data-media-element]');
      if (video instanceof HTMLVideoElement) {
        if (video.readyState >= 1) {
          setOrientation(slide, video.videoWidth, video.videoHeight);
        } else {
          video.addEventListener('loadedmetadata', () => {
            setOrientation(slide, video.videoWidth, video.videoHeight);
          });
        }
      }
    });

    const startAutoplay = () => {
      if (!canAutoplay() || pointerInside || focusInside || autoplayTimer !== null) {
        return;
      }

      autoplayTimer = window.setInterval(() => {
        move(1, false);
      }, autoplayInterval);
    };

    const pauseAutoplay = () => {
      clearAutoplay();
      clearResumeTimer();
    };

    const scheduleResume = () => {
      clearResumeTimer();

      if (!canAutoplay() || pointerInside || focusInside) {
        return;
      }

      resumeTimer = window.setTimeout(() => {
        startAutoplay();
      }, 1400);
    };

    const render = () => {
      slides.forEach((slide, index) => {
        const isActive = index === activeIndex;
        slide.dataset.active = String(isActive);
        slide.setAttribute('aria-hidden', String(!isActive));

        const video = slide.querySelector('video[data-video-slide]');
        if (!(video instanceof HTMLVideoElement)) {
          return;
        }

        if (isActive && video.dataset.autoplay === 'true') {
          void video.play().catch(() => {});
          return;
        }

        if (!video.controls) {
          video.pause();
        }
      });

      if (current) {
        current.textContent = String(activeIndex + 1);
      }
    };

    const move = (step, fromInteraction = true) => {
      activeIndex = (activeIndex + step + slides.length) % slides.length;
      render();

      if (fromInteraction) {
        pauseAutoplay();
        scheduleResume();
      }
    };

    if (prev instanceof HTMLButtonElement) {
      prev.addEventListener('click', (event) => {
        event.stopPropagation();
        move(-1, true);
      });
    }

    if (next instanceof HTMLButtonElement) {
      next.addEventListener('click', (event) => {
        event.stopPropagation();
        move(1, true);
      });
    }

    if (viewport instanceof HTMLElement && slides.length > 1) {
      viewport.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          move(-1, true);
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          move(1, true);
        }
      });
    }

    carousel.addEventListener('pointerenter', () => {
      pointerInside = true;
      pauseAutoplay();
    });

    carousel.addEventListener('pointerleave', () => {
      pointerInside = false;
      scheduleResume();
    });

    carousel.addEventListener('focusin', () => {
      focusInside = true;
      pauseAutoplay();
    });

    carousel.addEventListener('focusout', () => {
      focusInside = carousel.contains(document.activeElement);
      if (!focusInside) {
        scheduleResume();
      }
    });

    const handleMotionPreference = () => {
      if (prefersReducedMotion.matches) {
        pauseAutoplay();
        return;
      }

      scheduleResume();
    };

    const handleVisibility = () => {
      pageHidden = document.visibilityState === 'hidden';
      if (pageHidden) {
        pauseAutoplay();
        return;
      }

      scheduleResume();
    };

    prefersReducedMotion.addEventListener('change', handleMotionPreference);
    document.addEventListener('visibilitychange', handleVisibility);

    render();
    startAutoplay();
      };
    }

    const hostCarousel = document.currentScript?.previousElementSibling;
    if (hostCarousel instanceof HTMLElement && hostCarousel.matches('[data-carousel]')) {
      window[initializeKey](hostCarousel);
    }
  })();
</script>

<style>
  .media-carousel {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 12rem;
  }

  .media-carousel-viewport {
    width: 100%;
    height: 100%;
    min-height: inherit;
    overflow: hidden;
    position: relative;
    z-index: 1;
    outline: none;
  }

  .media-carousel-viewport:focus-visible {
    box-shadow: inset 0 0 0 2px color-mix(in oklab, var(--accent) 80%, #ffffff 20%);
  }

  .media-carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 0;
  }

  .media-slide {
    position: absolute;
    inset: 0;
    height: 100%;
    min-height: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 320ms ease;
    will-change: opacity;
  }

  .media-slide[data-active='true'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .media-slide {
      transition: none;
    }
  }

  .media-frame,
  .media-empty {
    width: 100%;
    height: 100%;
    min-height: 0;
    background: color-mix(in oklab, var(--surface) 92%, #000 8%);
    display: grid;
    place-items: center;
    position: relative;
    overflow: hidden;
  }

  .media-frame img,
  .media-frame video {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: center;
    transform: none;
    filter: saturate(0.92) contrast(1.03);
    background: color-mix(in oklab, var(--surface) 94%, #000 6%);
  }

  .media-slide[data-orientation='portrait'] .media-frame {
    padding: clamp(0.35rem, 0.8vw, 0.7rem);
    background: color-mix(in oklab, var(--surface) 90%, #000 10%);
  }

  .media-slide[data-orientation='portrait'] .media-frame img,
  .media-slide[data-orientation='portrait'] .media-frame video {
    object-fit: contain;
    transform: none;
  }

  .media-carousel[data-force-contain='true'] .media-frame {
    padding: clamp(0.55rem, 1.1vw, 0.95rem);
    background: #000000;
  }

  .media-carousel[data-force-contain='true'] .media-carousel-viewport {
    background: #000000;
  }

  .media-carousel[data-force-contain='true'] .media-frame img,
  .media-carousel[data-force-contain='true'] .media-frame video {
    object-fit: contain;
    object-position: center;
    transform: none !important;
    filter: none;
  }

  .media-empty {
    display: none;
    text-transform: uppercase;
    font: 700 0.55rem/1.4 'Inter', sans-serif;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.74);
    border: 1px dashed rgba(255, 255, 255, 0.2);
    text-align: center;
    padding: 0.55rem;
  }

  .media-empty.is-visible {
    display: grid;
  }

  .media-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, color-mix(in oklab, var(--tint) 50%, transparent) 4%, transparent 43%),
      linear-gradient(330deg, color-mix(in oklab, var(--card) 66%, transparent) 0%, transparent 58%),
      color-mix(in oklab, var(--tint) 18%, transparent);
    mix-blend-mode: multiply;
    pointer-events: none;
    z-index: 2;
  }

  .media-carousel-controls {
    position: absolute;
    right: 0.55rem;
    bottom: 0.55rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    padding: 0.22rem;
  }

  .media-control {
    border: 0;
    border-radius: 999px;
    padding: 0.34rem 0.62rem;
    background: color-mix(in oklab, var(--surface) 78%, #000 22%);
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    font: 700 0.5rem/1 'Inter', sans-serif;
    cursor: pointer;
  }

  .media-control:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .media-counter {
    margin: 0;
    min-width: 2.2rem;
    text-align: center;
    color: #ffffff;
    text-transform: uppercase;
    font: 700 0.5rem/1 'Inter', sans-serif;
    letter-spacing: 0.14em;
  }
</style>
