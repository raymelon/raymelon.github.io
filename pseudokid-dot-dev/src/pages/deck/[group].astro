<script>
  // Mobile menu functionality
  const hamburgerBtn = document.querySelector('.hamburger-btn');
  const mobileMenu = document.querySelector('.mobile-menu');
  const mobileMenuClose = document.querySelector('.mobile-menu-close');
  const mobileMenuLinks = document.querySelectorAll('.mobile-menu-link');

  function openMobileMenu() {
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeMobileMenu() {
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }

  if (hamburgerBtn) {
    hamburgerBtn.addEventListener('click', () => {
      const isExpanded = hamburgerBtn.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMobileMenu();
      } else {
        openMobileMenu();
      }
    });
  }

  if (mobileMenuClose) {
    mobileMenuClose.addEventListener('click', closeMobileMenu);
  }

  mobileMenuLinks.forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Close menu when clicking on brand logo
  const mobileMenuBrand = document.querySelector('.mobile-menu-brand');
  if (mobileMenuBrand) {
    mobileMenuBrand.addEventListener('click', closeMobileMenu);
  }

  if (mobileMenu) {
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMobileMenu();
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (
      e.key === 'Escape' &&
      mobileMenu?.getAttribute('aria-hidden') === 'false'
    ) {
      closeMobileMenu();
    }
  });

  // Contact modal
  const deckContactBtn = document.getElementById('deck-contact-btn');
  const contactModal = document.getElementById('deck-contact-modal');
  const contactBackdrop = document.getElementById('deck-contact-modal-backdrop');
  const contactClose = document.getElementById('deck-contact-modal-close');
  
  if (contactModal && contactBackdrop && contactClose) {
    function openContactModal() {
      contactModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    
    function closeContactModal() {
      contactModal.classList.remove('active');
      document.body.style.overflow = '';
    }
    
    if (deckContactBtn) deckContactBtn.addEventListener('click', openContactModal);
    contactBackdrop.addEventListener('click', closeContactModal);
    contactClose.addEventListener('click', closeContactModal);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && contactModal.classList.contains('active')) {
        closeContactModal();
      }
    });

    // Copy functionality
    const copyIcons = contactModal.querySelectorAll('.contact-modal-copy-icon');
    copyIcons.forEach(icon => {
      icon.addEventListener('click', async () => {
        const row = icon.closest('.contact-modal-row');
        const valueEl = row ? row.querySelector('.contact-modal-value') : null;
        const value = valueEl ? valueEl.textContent?.trim() : null;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          const iconSpan = icon.querySelector('.material-symbols-outlined') || icon;
          const originalText = iconSpan.textContent;
          iconSpan.textContent = 'check';
          setTimeout(() => {
            iconSpan.textContent = originalText ?? 'content_copy';
          }, 1500);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  }

  // Handle mobile contact button - opens modal and closes menu
  const mobileContactBtn = document.getElementById('mobile-contact-btn-deck');
  if (mobileContactBtn) {
    mobileContactBtn.addEventListener('click', () => {
      closeMobileMenu();
      const modal = document.getElementById('deck-contact-modal');
      if (modal) {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  }

  // Scroll handler for compact header and floating footer
  const footer = document.querySelector('.site-footer');
  const embeddedFooter = document.querySelector('.site-footer-embedded');
  const siteNav = document.querySelector('.site-nav');

  function handleScroll() {
    const scrollY = window.scrollY || window.pageYOffset;

    // Compact header after 5% scroll
    if (scrollY > window.innerHeight * 0.05) {
      siteNav?.classList.add('compact');
    } else {
      siteNav?.classList.remove('compact');
    }

    // Check if we're near the bottom (within 100px of the embedded footer)
    const embeddedFooterRect = embeddedFooter?.getBoundingClientRect();
    const isNearBottom = embeddedFooterRect && embeddedFooterRect.top < window.innerHeight + 100;

    // Show floating footer always, except when near bottom
    if (!isNearBottom) {
      footer?.classList.add('visible');
      footer?.setAttribute('aria-hidden', 'false');
    } else {
      footer?.classList.remove('visible');
      footer?.setAttribute('aria-hidden', 'true');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Scroll to Top Button functionality
  const scrollToTopBtn = document.querySelector('.scroll-to-top');

  if (scrollToTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        scrollToTopBtn.classList.add('visible');
        scrollToTopBtn.removeAttribute('hidden');
      } else {
        scrollToTopBtn.classList.remove('visible');
        scrollToTopBtn.setAttribute('hidden', 'true');
      }

      // Move scroll-to-top button up when footer is visible
      const scrollY = window.scrollY || window.pageYOffset;
      const threshold = window.innerHeight * 0.05;
      if (scrollY > threshold * 2) {
        scrollToTopBtn.classList.add('footer-visible');
      } else {
        scrollToTopBtn.classList.remove('footer-visible');
      }
    });

    scrollToTopBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<script is:inline>
  (() => {
    const goBack = () => {
      const fromSameSite = document.referrer && new URL(document.referrer).origin === window.location.origin;
      if (fromSameSite) {
        window.history.back();
        return;
      }

      window.location.assign('/');
    };

    const handles = document.querySelectorAll('[data-history-back]');
    handles.forEach((handle) => {
      handle.addEventListener('click', (event) => {
        if (!(event instanceof MouseEvent)) {
          return;
        }

        event.preventDefault();
        goBack();
      });
    });
  })();
</script>

