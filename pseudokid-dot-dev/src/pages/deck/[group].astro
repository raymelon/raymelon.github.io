        {deck.stats.map((stat) => (
          <li>
            <strong>{stat.value}</strong>
            <span>{stat.label}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="project-list" aria-label={`${deck.title} projects`}>
      {deck.projects.map((project) => {
        const projectAssets = getProjectAssets(project).slice(0, 4);
        const hasMedia = projectAssets.length > 0;
        const useMasonry = usesMasonryMediaLayout(project.name);
        const metricItems = getProjectMetricItems(project, 2);
        const theme = getProjectTheme(project);
        const displayMetric = metricItems.find((m) => m.value !== null) ?? (
          project.year ? { value: project.year, label: 'Year' } : null
        );

        return (
          <article
            class={`project-card ${hasMedia ? 'has-media' : 'no-media'} ${hasMedia ? (useMasonry ? 'media-vertical' : 'media-horizontal') : ''}`}
            style={`--card:${theme.card};--surface:${theme.surface};--accent:${theme.accent};`}
          >
            <div>
              <div class="project-head">
                <p class="project-kind">Project</p>
                <p class="project-year">{project.year ?? ''}</p>
              </div>
              <h2>{project.name}</h2>
              <p class="project-copy">{project.tagline ?? project.description ?? 'Product brief'}</p>
              {displayMetric ? (
                <ul class="metric-grid">
                  <li>
                    {displayMetric.value ? <strong>{displayMetric.value}</strong> : null}
                    <span>{displayMetric.label}</span>
                  </li>
                </ul>
              ) : null}
            </div>

            <div class="project-media">
              {hasMedia ? (
                <div class="media-shell">
                  {useMasonry ? (
                    <MediaMasonry assets={projectAssets} projectName={project.name} label={`${project.name} media preview`} />
                  ) : (
                    <MediaCarousel
                      assets={projectAssets}
                      projectName={project.name}
                      label={`${project.name} media preview`}
                      showControls={projectAssets.length > 1}
                    />
                  )}
                </div>
              ) : (
                <div class="media-shell media-placeholder" aria-hidden="true">
                  <span class="placeholder-label">No preview</span>
                </div>
              )}
              <span class="asset-tag">{getAssetTag(projectAssets)}</span>
            </div>

            <div class="project-actions">
              <a class="brief-cta" href={getProjectBriefHref(project)}>Open Brief</a>
              {project.url ? <a href={project.url} target="_blank" rel="noreferrer noopener">Visit Project</a> : null}
            </div>
          </article>
        );
      })}
    </section>
