---
import Layout from '../../layouts/Layout.astro';
import MediaCarousel from '../../components/MediaCarousel.astro';
import MediaMasonry from '../../components/MediaMasonry.astro';
import {
  assertInclusionParity,
  getAllProjects,
  getGroupDeckModels,
  getProjectAssets,
  getProjectBriefHref,
  getProjectMetricItems,
  getProjectTheme,
  isImageAsset,
  isVideoAsset,
  usesMasonryMediaLayout
} from '../../lib/portfolio';

export function getStaticPaths() {
  const allProjects = getAllProjects();
  const decks = getGroupDeckModels(allProjects);
  const renderedEntities = decks.reduce((total, deck) => total + deck.projects.length, 0);
  assertInclusionParity(renderedEntities, 'group deck routes');

  return decks.map((deck) => ({
    params: { group: deck.id },
    props: { deck }
  }));
}

const { deck } = Astro.props;

function getAssetTag(assets: string[]) {
  if (assets.length > 2) {
    return `${assets.length} item collage`;
  }

  if (assets.length > 1) {
    return 'Dual media';
  }

  const firstAsset = assets[0];
  if (isVideoAsset(firstAsset)) {
    return 'Video preview';
  }

  if (isImageAsset(firstAsset)) {
    return 'Image preview';
  }

  return firstAsset ? 'Mixed media' : 'No media';
}
