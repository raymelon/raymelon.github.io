  /* Quick Wins Carousel (inside How I Ship) */
  .quick-wins-carousel {
    margin-top: 3rem;
    position: relative;
    overflow: hidden;
  }

  .quick-wins-track {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  @media (max-width: 1040px) {
    .quick-wins-track {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .quick-wins-track {
      grid-template-columns: 1fr;
    }
  }

  .ship-card {
    --ship-color: #f59e0b;
    position: relative;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    background: transparent;
    overflow: visible;
    transition: transform 0.15s ease;
    opacity: 0;
    transform: translateY(4px);
  }

  .ship-card.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition:
      opacity 260ms ease,
      transform 260ms ease;
  }

  .ship-card::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    right: 0;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgba(45, 91, 255, 0) 0%,
      rgba(45, 91, 255, 0.35) 22%,
      rgba(45, 91, 255, 0.35) 78%,
      rgba(45, 91, 255, 0) 100%
    );
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .ship-card::after {
      width: 0.75px;
    }
  }

  .ship-card:hover {
    transform: translateY(0) translate(-2px, -2px);
  }

