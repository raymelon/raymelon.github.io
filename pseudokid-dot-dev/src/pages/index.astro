<script>
  // Contact modal
  (function() {
    const btn = document.getElementById('contact-modal-btn');
    const modal = document.getElementById('contact-modal');
    const backdrop = document.getElementById('contact-modal-backdrop');
    const close = document.getElementById('contact-modal-close');
    
    if (!btn || !modal || !backdrop || !close) return;
    
    function openModal() {
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    
    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }
    
    btn.addEventListener('click', openModal);
    backdrop.addEventListener('click', closeModal);
    close.addEventListener('click', closeModal);
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('active')) {
        closeModal();
      }
    });

    // Copy functionality
    const copyIcons = modal.querySelectorAll('.contact-modal-copy-icon');
    copyIcons.forEach(icon => {
      icon.addEventListener('click', async () => {
        const row = icon.closest('.contact-modal-row');
        const valueEl = row ? row.querySelector('.contact-modal-value') : null;
        const value = valueEl ? valueEl.textContent?.trim() : null;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          const iconSpan = icon.querySelector('.material-symbols-outlined') || icon;
          const originalText = iconSpan.textContent;
          iconSpan.textContent = 'check';
          setTimeout(() => {
            iconSpan.textContent = originalText ?? 'content_copy';
          }, 1500);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  })();
</script>

<script>
  // ASCII / Dot-matrix portrait renderer
  (function () {
    const canvas = document.getElementById("ascii-canvas") as HTMLCanvasElement;
    const img = document.getElementById("ascii-source") as HTMLImageElement;
    if (!canvas || !img) return;

    const CHAR_SET = "@%#*+=-:. ";
    const BLUE = { r: 45, g: 91, b: 255 };
    const YELLOW = { r: 255, g: 255, b: 0 };

    function lerp(a: number, b: number, t: number) {
      return a + (b - a) * t;
    }

    function renderASCII() {
      const ctx = canvas.getContext("2d");
      if (!ctx) return;

      const wrap = canvas.parentElement;
      if (!wrap) return;

      const dpr = window.devicePixelRatio || 1;
      const wrapW = wrap.clientWidth;
      const wrapH = wrap.clientHeight;

      // Font size controls "resolution" — smaller = denser
      // Tuned for higher detail on the About Me photo.
      const fontSize = Math.max(0.75, Math.min(2, wrapW / 2.5));
      const charW = fontSize * 0.4;
      const charH = fontSize * 0.8;

      const cols = Math.floor(wrapW / charW);
      const rows = Math.floor(wrapH / charH);

      canvas.width = wrapW * dpr;
      canvas.height = wrapH * dpr;
      canvas.style.width = wrapW + "px";
      canvas.style.height = wrapH + "px";
      // Reset transform so repeated renders don't accumulate scaling.
      ctx.setTransform(1, 0, 0, 1, 0, 0);
      ctx.scale(dpr, dpr);

      // Draw source image to offscreen canvas to sample pixels
      const offscreen = document.createElement("canvas");
      offscreen.width = cols;
      offscreen.height = rows;
      const offCtx = offscreen.getContext("2d");
      if (!offCtx) return;

      offCtx.drawImage(img, 0, 0, cols, rows);
      const imageData = offCtx.getImageData(0, 0, cols, rows);
      const pixels = imageData.data;

      // Estimate background color by sampling corners (works well for solid/flat backdrops).
      function samplePixel(x: number, y: number) {
        const i = (y * cols + x) * 4;
        return { r: pixels[i], g: pixels[i + 1], b: pixels[i + 2] };
      }

      const cornerSamples = [
        samplePixel(0, 0),
        samplePixel(cols - 1, 0),
        samplePixel(0, rows - 1),
        samplePixel(cols - 1, rows - 1),
      ];
      const bg = cornerSamples.reduce(
        (acc, c) => ({ r: acc.r + c.r, g: acc.g + c.g, b: acc.b + c.b }),
        { r: 0, g: 0, b: 0 },
      );
      bg.r /= cornerSamples.length;
      bg.g /= cornerSamples.length;
      bg.b /= cornerSamples.length;

      const bgThreshold = 22; // higher = more aggressive background removal

      // Clear canvas
      ctx.fillStyle = "#000000";
      ctx.fillRect(0, 0, wrapW, wrapH);

      ctx.font = `${fontSize}px "Courier New", monospace`;
      ctx.textBaseline = "top";

      for (let row = 0; row < rows; row++) {
        for (let col = 0; col < cols; col++) {
          const idx = (row * cols + col) * 4;
          const r = pixels[idx];
          const g = pixels[idx + 1];
          const b = pixels[idx + 2];

          // Perceived brightness (0-1)
          const brightness = (0.299 * r + 0.587 * g + 0.114 * b) / 255;

          // Tone curve: lift shadows so dark areas aren't crushed
          const tone = Math.pow(brightness, 0.5);

          // Eliminate heavy shadows: skip low-tone pixels entirely.
          if (tone < 0.15) continue;

          // Background removal
          // 1) Remove pixels close to the estimated background color
          const dr = r - bg.r;
          const dg = g - bg.g;
          const db = b - bg.b;
          const bgDist = Math.sqrt(dr * dr + dg * dg + db * db);
          if (bgDist < bgThreshold) continue;

          // Map brightness to character (inverted: bright = dense char)
          const charIdx = Math.floor((1 - tone) * (CHAR_SET.length - 1));
          const char = CHAR_SET[charIdx];

          // Color: dark pixels → blue, bright pixels → yellow
          const cr = Math.round(lerp(BLUE.r, YELLOW.r, tone));
          const cg = Math.round(lerp(BLUE.g, YELLOW.g, tone));
          const cb = Math.round(lerp(BLUE.b, YELLOW.b, tone));

          // 2) Remove near-white/grey sticker border and highlights (keep this conservative)
          const maxC = Math.max(r, g, b);
          const minC = Math.min(r, g, b);
          const satRange = maxC - minC;
          if (brightness > 0.96 && satRange < 45) continue;

          // Alpha ramps up from midtones; shadows are mostly transparent.
          const alpha = Math.min(0.9, Math.max(0, (tone - 0.1) / 0.8));

          ctx.fillStyle = `rgba(${cr}, ${cg}, ${cb}, ${alpha})`;
          ctx.fillText(char, col * charW, row * charH);
        }
      }
    }

    function triggerRender() {
      if (img.complete && img.naturalWidth > 0) {
        renderASCII();
      } else {
        img.addEventListener("load", renderASCII, { once: true });
      }
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        triggerRender();
      });
    }, { rootMargin: "200px" });

    observer.observe(canvas);

    // Re-render on resize
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener("resize", () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(renderASCII, 200);
    });
  })();
</script>

