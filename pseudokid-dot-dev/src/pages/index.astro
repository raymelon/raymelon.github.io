        const wrapH = fixedHeight || wrap.clientHeight;

        // Fine-grained like About Me section - smaller font = higher detail
        const densityDivisor = fontDensityDivisor ?? 80; // default: 80 (original), higher = finer detail
        const fontSize = Math.max(1.5, Math.min(3, wrapW / densityDivisor));
        const charW = fontSize * 0.5;
        const charH = fontSize * 0.85;

        const cols = Math.floor(wrapW / charW);
        const rows = Math.floor(wrapH / charH);

        canvas.width = wrapW * dpr;
        canvas.height = wrapH * dpr;
        canvas.style.width = wrapW + "px";
        canvas.style.height = wrapH + "px";
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        const offscreen = document.createElement("canvas");
        offscreen.width = cols;
        offscreen.height = rows;
        const offCtx = offscreen.getContext("2d");
        if (!offCtx) return;

        offCtx.drawImage(img, 0, 0, cols, rows);
        const imageData = offCtx.getImageData(0, 0, cols, rows);
        const pixels = imageData.data;

        ctx.fillStyle = "#0a0a0a";
        ctx.fillRect(0, 0, wrapW, wrapH);

        ctx.font = `${fontSize}px "Courier New", monospace`;
        ctx.textBaseline = "top";

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            const idx = (row * cols + col) * 4;
            const r = pixels[idx];
            const g = pixels[idx + 1];
            const b = pixels[idx + 2];

            const brightness = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
            const tone = Math.pow(brightness, 0.7);

            if (tone < 0.05) continue;

            // FIXED: Remove inversion - bright areas get dense chars
            const charIdx = Math.floor(tone * (CHAR_SET.length - 1));
            const char = CHAR_SET[charIdx];

            if (colorTint) {
              // FIXED: Blend tint with original colors instead of solid color
              const blendStrength = 0.6; // 60% tint, 40% original
              const alpha = 0.75 + tone * 0.25;
              const finalR = Math.round(
                colorTint.r * blendStrength + r * (1 - blendStrength),
              );
              const finalG = Math.round(
                colorTint.g * blendStrength + g * (1 - blendStrength),
              );
              const finalB = Math.round(
                colorTint.b * blendStrength + b * (1 - blendStrength),
              );
              ctx.fillStyle = `rgba(${finalR}, ${finalG}, ${finalB}, ${alpha})`;
            } else {
              // Preserve original colors - BRIGHTER
              const alpha = 0.95 + tone * 0.05;
              const brightR = Math.min(255, r * 1.3);
              const brightG = Math.min(255, g * 1.3);
              const brightB = Math.min(255, b * 1.3);
              ctx.fillStyle = `rgba(${brightR}, ${brightG}, ${brightB}, ${alpha})`;
            }

            ctx.fillText(char, col * charW, row * charH);
          }
        }
      }

      function triggerRender() {
        if (img.complete && img.naturalWidth > 0) {
          doRender();
        } else {
          img.addEventListener("load", doRender, { once: true });
        }
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          triggerRender();
        });
      }, { rootMargin: "200px" });

      observer.observe(canvas);

      let resizeTimer: ReturnType<typeof setTimeout>;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(doRender, 200);
      });
    }

    function init() {
      // Might be you card - no tint (null), preserve original colors, uses parent container dimensions
      renderPortfolioAscii(
        "portfolio-ascii-might-be-you",
        "portfolio-img-might-be-you",
        null,
      );

      // Founders card - purple tint, fixed 250x200 dimensions, ultra-fine detail (density divisor 250)
      renderPortfolioAscii(
        "founders-ascii-canvas",
        "founders-ascii-source",
        { r: 168, g: 85, b: 247 },
        250,
        200,
        250,
      );

      // Solopreneurs card - green tint, fixed 250x200 dimensions, ultra-fine detail (density divisor 250)
      renderPortfolioAscii(
        "solopreneurs-ascii-canvas",
        "solopreneurs-ascii-source",
        { r: 34, g: 197, b: 94 },
        250,
        200,
        250,
      );
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>

<script>
  // Testimonial expandable text functionality
  (function () {
    const textWraps = document.querySelectorAll("[data-testimonial-text]");

    textWraps.forEach((wrap) => {
      const text = wrap.querySelector(".testimonial-text");
      const button = wrap.querySelector(".testimonial-see-more");

      if (!text || !button) return;

      // Check if text exceeds 4 lines
      const lineHeight = parseInt(window.getComputedStyle(text).lineHeight);
      const maxHeight = lineHeight * 4;

      if (text.scrollHeight <= maxHeight) {
        // Text fits in 4 lines, hide button
        button.style.display = "none";
      } else {
        // Text exceeds 4 lines, add collapsed class and show button
        wrap.classList.add("is-collapsed");

        // Set initial button text
        button.textContent = "See more";

        button.addEventListener("click", () => {
          const isCollapsed = wrap.classList.contains("is-collapsed");

          if (isCollapsed) {
            wrap.classList.remove("is-collapsed");
            button.setAttribute("aria-expanded", "true");
            button.textContent = "See less";
          } else {
            wrap.classList.add("is-collapsed");
            button.setAttribute("aria-expanded", "false");
            button.textContent = "See more";
          }
        });
      }
    });
  })();
</script>

<script>
  // Mobile menu functionality
  const hamburgerBtn = document.querySelector(".hamburger-btn");
  const mobileMenu = document.querySelector(".mobile-menu");
  const mobileMenuClose = document.querySelector(".mobile-menu-close");
  const mobileMenuLinks = document.querySelectorAll(".mobile-menu-link");

  function openMobileMenu() {
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.setAttribute("aria-expanded", "true");
      mobileMenu.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }
  }

  function closeMobileMenu() {
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.setAttribute("aria-expanded", "false");
      mobileMenu.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }
  }

  if (hamburgerBtn) {
    hamburgerBtn.addEventListener("click", () => {
      const isExpanded = hamburgerBtn.getAttribute("aria-expanded") === "true";
      if (isExpanded) {
        closeMobileMenu();
      } else {
        openMobileMenu();
      }
    });
  }

  if (mobileMenuClose) {
    mobileMenuClose.addEventListener("click", closeMobileMenu);
  }

  mobileMenuLinks.forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  // Close menu when clicking outside
  if (mobileMenu) {
    mobileMenu.addEventListener("click", (e) => {
      if (e.target === mobileMenu) {
        closeMobileMenu();
      }
    });
  }

  // Close menu on Escape key
  document.addEventListener("keydown", (e) => {
    if (
      e.key === "Escape" &&
      mobileMenu?.getAttribute("aria-hidden") === "false"
    ) {
      closeMobileMenu();
    }
  });

  // Get footer element
  const footer = document.querySelector(".site-footer");
  const scrollIndicator = document.querySelector(".scroll-indicator");
  const hero = document.querySelector(".hero");
  const heroTicker = document.querySelector(".hero-ticker");
  let hideTimer = null;

  // Calculate threshold: 50% of viewport height
  const getThreshold = () => window.innerHeight * 0.5;

  // Check if near end of page (within last 200px)
  const isNearEnd = () => {
    const scrollY = window.scrollY || window.pageYOffset;
    const docHeight = document.documentElement.scrollHeight;
    const winHeight = window.innerHeight;
    return scrollY + winHeight >= docHeight - 200;
  };

  // Check if we've scrolled past the hero ticker
  const hasScrolledPastTicker = () => {
    if (!heroTicker) return false;
    const tickerRect = heroTicker.getBoundingClientRect();
    return tickerRect.bottom < 0;
  };

  // Scroll handler - show footer when scrolled 50% of viewport
  function handleScroll() {
    const scrollY = window.scrollY || window.pageYOffset;
    const threshold = getThreshold();
    const siteNav = document.querySelector(".site-nav");
    const scrollToTopBtn = document.querySelector(".scroll-to-top");

    if (scrollY > threshold) {
      if (!isNearEnd()) {
        footer.classList.add("visible");
        footer.setAttribute("aria-hidden", "false");
      } else {
        footer.classList.remove("visible");
        footer.setAttribute("aria-hidden", "true");
      }
      // Compact header when scrolled past threshold
      siteNav?.classList.add("compact");

      // Move scroll-to-top button up to avoid footer
      scrollToTopBtn?.classList.add("footer-visible");
    } else {
      footer.classList.remove("visible");
      footer.setAttribute("aria-hidden", "true");

      // Restore header padding
      siteNav?.classList.remove("compact");

      // Restore scroll-to-top button position
      scrollToTopBtn?.classList.remove("footer-visible");
    }

    // Handle scroll indicator position and visibility
    if (scrollIndicator) {
      // Hide when near end of page
      if (isNearEnd()) {
        // Clear any pending hide timer
        if (hideTimer) {
          clearTimeout(hideTimer);
          hideTimer = null;
        }
        scrollIndicator.style.opacity = "0";
        scrollIndicator.style.pointerEvents = "none";
      } else {
        // Position: center vertically in hero, bottom-right on mobile, bottom-left on desktop after ticker
        const isDesktop = window.innerWidth >= 1024;
        if (hasScrolledPastTicker()) {
          scrollIndicator.style.top = "auto";
          scrollIndicator.style.bottom = "2rem";
          scrollIndicator.style.transform = "none";
          if (isDesktop) {
            scrollIndicator.style.left = "2rem";
            scrollIndicator.style.right = "auto";
          } else {
            scrollIndicator.style.right = "2rem";
            scrollIndicator.style.left = "auto";
          }
          // Fade out after half a second when at bottom
          if (!hideTimer) {
            scrollIndicator.style.opacity = "1";
            scrollIndicator.style.pointerEvents = "auto";
            hideTimer = setTimeout(() => {
              scrollIndicator.style.opacity = "0";
              scrollIndicator.style.pointerEvents = "none";
            }, 500);
          }
        } else {
          // Clear the timer if scrolling back up
          if (hideTimer) {
            clearTimeout(hideTimer);
            hideTimer = null;
          }
          scrollIndicator.style.opacity = "1";
          scrollIndicator.style.pointerEvents = "auto";
          scrollIndicator.style.top = "50%";
          scrollIndicator.style.bottom = "auto";
          scrollIndicator.style.transform = "translateY(-50%)";
          if (isDesktop) {
            scrollIndicator.style.left = "2rem";
            scrollIndicator.style.right = "auto";
          } else {
            scrollIndicator.style.right = "2rem";
            scrollIndicator.style.left = "auto";
          }
        }
      }
    }
  }

  // Initial check
  handleScroll();

  // Add scroll listener (passive for performance)
  window.addEventListener("scroll", handleScroll, { passive: true });

  // Handle resize to update threshold
  window.addEventListener("resize", handleScroll);

  // Handle short pages (not scrollable)
  function isPageScrollable() {
    return (
      document.documentElement.scrollHeight >
      document.documentElement.clientHeight
    );
  }

  if (!isPageScrollable()) {
    footer.classList.add("visible");
    footer.setAttribute("aria-hidden", "false");
  }

  // Scroll to Top Button functionality
  const scrollToTopBtn = document.querySelector(".scroll-to-top");

  if (scrollToTopBtn) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 300) {
        scrollToTopBtn.classList.add("visible");
        scrollToTopBtn.removeAttribute("hidden");
      } else {
        scrollToTopBtn.classList.remove("visible");
        scrollToTopBtn.setAttribute("hidden", "true");
      }
    });

    scrollToTopBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }
</script>

<script>
  // Tech Stack search + category filter
  const techSearch = document.getElementById("tech-search") as HTMLInputElement;
  const techGrid = document.getElementById("tech-grid");
  const filterCapsules = document.getElementById("tech-filter-capsules");

  if (techSearch && techGrid && filterCapsules) {
    const tiles = techGrid.querySelectorAll(
      ".tech-tile",
    ) as NodeListOf<HTMLElement>;
    const capsules = filterCapsules.querySelectorAll(
      ".tech-filter-capsule",
    ) as NodeListOf<HTMLButtonElement>;
    let activeCategory = "all";

    function applyFilters() {
      const query = techSearch.value.toLowerCase().trim();
      tiles.forEach((tile) => {
        const techName = (tile.getAttribute("data-tech") || "").toLowerCase();
        const category = (
          tile.getAttribute("data-category") || ""
        ).toLowerCase();
        const matchesQuery =
          !query || techName.includes(query) || category.includes(query);
        const matchesCategory =
          activeCategory === "all" || category === activeCategory;
        if (matchesQuery && matchesCategory) {
          tile.classList.remove("hidden");
        } else {
          tile.classList.add("hidden");
        }
      });
    }

    techSearch.addEventListener("input", applyFilters);

    capsules.forEach((capsule) => {
      capsule.addEventListener("click", () => {
        activeCategory = capsule.getAttribute("data-filter") || "all";
        capsules.forEach((c) => c.classList.remove("active"));
        capsule.classList.add("active");
        applyFilters();
      });
    });
  }
</script>

