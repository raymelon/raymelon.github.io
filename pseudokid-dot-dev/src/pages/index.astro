    writing-mode: vertical-rl;
    text-orientation: mixed;
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.4);
  }

  .bg-brutalist-yellow {
    background-color: #ffff00;
  }

  .highlight-blue {
    color: #3b82f6;
  }

  .highlight-yellow {
    color: #fbbf24;
  }

  .hero-ticker {
    margin-top: 3rem;
    width: 100dvw;
    max-width: 100dvw;
    margin-inline: calc(50% - 50dvw);
    overflow: clip;
  }

  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.5rem;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: blur(14px);
    transform: translateY(100%);
    opacity: 0;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform, opacity;
  }

  @media (min-width: 761px) {
    .site-footer {
      padding: 1.25rem 2.5rem;
    }
  }

  .site-footer.visible {
    transform: translateY(0);
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-footer {
      transition: none;
    }
  }

  .footer-content {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
  }

  .status-dot {
    width: 0.5rem;
    height: 0.5rem;
    background: #3b82f6;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }

  .footer-links {
    display: flex;
    gap: 3rem;
  }

  @media (max-width: 640px) {
    .footer-status,
    .footer-links {
      width: 100%;
    }

    .footer-links {
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 1.5rem;
    }
  }

  .footer-links a {
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: #ffff00;
  }

  /* Embedded footer */
  .site-footer-embedded {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 3rem 1.5rem 4rem;
  }

  @media (min-width: 761px) {
    .site-footer-embedded {
      padding: 3rem 2.5rem 4.5rem;
    }
  }

  .footer-embedded-content {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .footer-brand-col {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-brand-link {
    text-decoration: none;
  }

  .footer-brand-link .brand-text {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 900;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .footer-brand-link .brand-dot {
    color: #3b82f6;
  }

  .footer-embedded-status {
    gap: 0.6rem !important;
  }

  .footer-right-col {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .footer-right-col .footer-links {
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-built-with {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.2);
    text-align: right;
    line-height: 1.8;
    overflow-wrap: break-word;
  }

  .fbw-sep {
    display: inline;
    white-space: pre;
  }

  /* Portfolio Header */
  .portfolio-section {
    padding-block: 1rem;
    max-width: 1280px;
    margin-inline: auto;
    scroll-margin-top: 6rem;
  }

  .portfolio-header {
    margin-bottom: 4rem;
    text-align: left;
  }

  .portfolio-title {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 1.5rem 0;
    color: #ffffff;
  }

  .portfolio-bar {
    width: 8rem;
    height: 0.5rem;
    background-color: #ffff00;
    margin-bottom: 2rem;
  }

  .portfolio-description {
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.6;
    color: rgba(148, 163, 184, 1);
    max-width: 48rem;
    margin: 0 0 2rem 0;
  }

  .portfolio-cta-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .portfolio-cta-heading {
    font-size: clamp(2.6rem, 11vw, 8rem);
    font-weight: 700;
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin: 0;
    font-family: "Manrope", sans-serif;
  }

  .portfolio-cta-yellow {
    color: #f0ff00;
    font-style: italic;
  }

  .portfolio-cta-blue {
    color: var(--brand);
    font-style: italic;
  }

  .portfolio-cta-block .wiw-card-btn {
    align-self: center;
  }

  /* Portfolio Grid - True Masonry with column-count */
  .portfolio-grid {
    column-count: 3;
    column-gap: 1rem;
    padding-bottom: 4rem;
  }

  @media (max-width: 1040px) {
    .portfolio-grid {
      column-count: 2;
    }
  }

  @media (max-width: 760px) {
    .portfolio-grid {
      column-count: 1;
    }
  }

  /* Portfolio Card - prevent breaking inside columns */
  .portfolio-card {
    break-inside: avoid;
    margin-bottom: 1.5rem;
  }

  /* Portfolio Card - Stitch Layout */
  .portfolio-card {
    position: relative;
    border-radius: 1.5rem;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.5s ease;
    box-sizing: border-box;
  }

  .portfolio-card-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    z-index: 5;
  }

  .portfolio-card:hover {
    transform: translateY(-8px);
  }

  /* Header: Tag + Number (Stitch style) */
  .portfolio-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3rem;
  }

  .portfolio-card-tag {
    background-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    line-height: 1;
  }

  .portfolio-card-number {
    font-size: 0.875rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: -0.02em;
  }

  /* Metric Section */
  .portfolio-card-metric {
    margin-bottom: 1.5rem;
  }

  .portfolio-card-metric-value {
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 0.85;
    letter-spacing: -0.06em;
    color: #ffffff;
    margin-bottom: 1.5rem;
  }

  .portfolio-card-metric-label {
    font-size: 0.875rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Headline */
  .portfolio-card-headline-wrapper {
    margin-bottom: 2.5rem;
  }

  .portfolio-card-headline {
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.9);
    max-width: 280px;
    margin: 0;
    font-family: "Inter", sans-serif;
  }

  /* Dark text for specific light-background decks: 01, 03, 04, 07 */
  [data-group-id="vibe-coded-games"] .portfolio-card-metric-value,
  [data-group-id="ai-ml-projects"] .portfolio-card-metric-value,
  [data-group-id="high-impact-products"] .portfolio-card-metric-value,
  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-metric-value {
    color: #0a0a0a;
  }

  [data-group-id="vibe-coded-games"] .portfolio-card-tag,
  [data-group-id="high-impact-products"] .portfolio-card-tag,
  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-tag {
    background-color: rgba(0, 0, 0, 0.3);
  }

  [data-group-id="vibe-coded-games"] .portfolio-card-metric-label,
  [data-group-id="ai-ml-projects"] .portfolio-card-metric-label,
  [data-group-id="high-impact-products"] .portfolio-card-metric-label,
  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-metric-label {
    color: rgba(10, 10, 10, 0.8);
  }

  [data-group-id="vibe-coded-games"] .portfolio-card-headline,
  [data-group-id="ai-ml-projects"] .portfolio-card-headline,
  [data-group-id="high-impact-products"] .portfolio-card-headline,
  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-headline {
    color: rgba(10, 10, 10, 0.9);
  }

  /* Media Section (Thumbnails + Button) */
  .portfolio-card-media {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: auto;
  }

  /* Thumbnail Grid (Stitch style - larger) */
  .portfolio-card-thumbnails {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .portfolio-card-thumbnail {
    border-radius: 16px;
    overflow: hidden;
    background-color: rgba(0, 0, 0, 0.2);
    transition: all 0.5s ease;
  }

  .portfolio-card-thumbnail img,
  .portfolio-card-thumbnail video {
    width: 100%;
    height: auto;
    display: block;
    transition: all 0.5s ease;
  }

  /* Decks 06 (index 5) and 07 (index 6): Force square aspect ratio */
  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-thumbnail,
  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail {
    aspect-ratio: 1;
  }

  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-thumbnail img,
  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail img,
  [data-group-id="just-for-fun-creator-tools"] .portfolio-card-thumbnail video,
  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail video {
    height: 100%;
    object-fit: cover;
  }

  .portfolio-card:hover .portfolio-card-thumbnail img {
    filter: grayscale(0);
  }

  .portfolio-card-thumbnail img {
    filter: grayscale(100%);
  }

  /* Decks 03, 04, 06: Use color tint based on bg instead of grayscale */
  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail img,
  [data-group-id="high-impact-products"] .portfolio-card-thumbnail img,
  [data-group-id="agentic-ai-automation"] .portfolio-card-thumbnail img {
    filter: none;
  }

  /* Tint overlays for 4-part thumbnail decks */
  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail,
  [data-group-id="high-impact-products"] .portfolio-card-thumbnail,
  [data-group-id="agentic-ai-automation"] .portfolio-card-thumbnail {
    position: relative;
  }

  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail::after,
  [data-group-id="high-impact-products"] .portfolio-card-thumbnail::after,
  [data-group-id="agentic-ai-automation"] .portfolio-card-thumbnail::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 12px;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  [data-group-id="ai-ml-projects"] .portfolio-card-thumbnail::after {
    background-color: rgba(16, 185, 129, 0.3); /* Emerald tint */
    mix-blend-mode: multiply;
  }

  [data-group-id="high-impact-products"] .portfolio-card-thumbnail::after {
    background-color: rgba(14, 165, 233, 0.3); /* Sky blue tint */
    mix-blend-mode: multiply;
  }

  [data-group-id="agentic-ai-automation"] .portfolio-card-thumbnail::after {
    background-color: rgba(51, 51, 51, 0.3); /* Gray tint */
    mix-blend-mode: multiply;
  }

  /* Remove tint on hover */
  [data-group-id="ai-ml-projects"]
    .portfolio-card:hover
    .portfolio-card-thumbnail::after,
  [data-group-id="high-impact-products"]
    .portfolio-card:hover
    .portfolio-card-thumbnail::after,
  [data-group-id="agentic-ai-automation"]
    .portfolio-card:hover
    .portfolio-card-thumbnail::after {
    opacity: 0;
  }

  /* Black container for 4-part thumbnail decks (03, 04, 06) */
  .portfolio-card-thumbnails-wrapper.has-black-container {
    background-color: #000000;
    border-radius: 12px;
    padding: 0.5rem;
  }

  .portfolio-card-thumbnails-wrapper.has-black-container
    .portfolio-card-thumbnails {
    gap: 0.5rem;
  }

  /* Carousel container for odd-count decks */
  .portfolio-card-carousel {
    width: 100%;
    height: 180px;
    border-radius: 12px;
    overflow: hidden;
  }

  .portfolio-card-carousel :global(.media-carousel) {
    height: 100%;
    min-height: 180px;
  }

  /* Spacer for placeholder cards */
  .portfolio-card-media-spacer {
    min-height: 180px;
    flex: 1;
  }

  /* Button (Stitch style - full width) */
  .portfolio-card-btn {
    display: block;
    width: 100%;
    padding: 1.25rem;
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #ffffff;
    background-color: rgba(0, 0, 0, 0.3);
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    z-index: 5;
    text-align: center;
    text-decoration: none;
  }

  .portfolio-card-btn:hover {
    background-color: #ffffff;
    color: #000000;
    text-decoration: none;
  }

  .portfolio-card-btn--inverted {
    background-color: #ffffff !important;
    color: #000000 !important;
    font-weight: 900 !important;
    -webkit-text-fill-color: #000000 !important;
    opacity: 1 !important;
    filter: none !important;
    border: 2px solid #ffffff !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3) !important;
  }

  .portfolio-card-btn--inverted:hover {
    background-color: #000000 !important;
    color: #ffffff !important;
    -webkit-text-fill-color: #ffffff !important;
    border-color: #000000 !important;
  }

  /* Placeholder Card */
  .portfolio-card-placeholder {
    background: linear-gradient(150deg, #1e2734 0%, #171b22 70%);
  }

  .contact {
    border-top: 1px solid var(--line);
    padding-block: clamp(2.8rem, 10vw, 7rem) clamp(2rem, 8vw, 4.6rem);
    display: grid;
    justify-items: center;
    gap: 1.3rem;
    text-align: center;
  }

  .contact h2 {
    font-size: clamp(2.6rem, 11vw, 8rem);
    line-height: 0.88;
    margin: 0;
    font-family: "Manrope", sans-serif;
    font-weight: 700;
  }

  .contact h2 span {
    color: #f0ff00;
    font-style: italic;
  }

  .contact-main-cta {
    text-decoration: none;
    border-radius: 999px;
    padding: 1rem 2rem;
    background: var(--text);
    color: #0a0a0a;
    font:
      700 0.9rem/1 "Manrope",
      sans-serif;
    letter-spacing: 0.04em;
    cursor: pointer;
    border: none;
  }

  .contact-tally-btn {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--line-strong);
  }

  .contact-tally-btn:hover {
    color: var(--text);
    border-color: var(--text);
  }

  /* Contact Modal - Clean Typography */
  .contact-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .contact-modal.active {
    display: flex;
  }

  .contact-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
    pointer-events: none;
  }

  .contact-modal-content {
    position: relative;
    background: var(--surface);
    padding: 2.5rem 2rem 2rem;
    max-width: 640px;
    width: 90%;
    border: 1px solid rgba(30, 41, 59, 0.8);
    text-align: left;
  }

  .contact-modal-close {
    position: absolute;
    top: 2.5rem;
    right: 2.5rem;
    background: none;
    border: none;
    color: var(--text);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0.25rem;
    transition: color 0.2s;
  }

  .contact-modal-close:hover {
    color: #f9f506;
  }

  .contact-modal-status {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
    font-family: "Inter", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.4);
  }

  .contact-modal-title {
    margin: 0 0 2.5rem;
    text-align: left;
    font-family: "Inter", sans-serif;
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.85;
    color: var(--text);
  }

  .contact-modal-title br {
    display: block;
  }

  .contact-modal-list {
    display: flex;
    flex-direction: column;
  }

  .contact-modal-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-top: 1px solid rgba(30, 41, 59, 0.6);
    gap: 1rem;
  }

  .contact-modal-row:first-child {
    border-top: none;
  }

  .contact-modal-row:last-child {
    border-bottom: 1px solid rgba(30, 41, 59, 0.6);
  }

  .contact-modal-row-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex: 1;
    min-width: 0;
  }

  .contact-modal-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    text-align: left;
    align-items: flex-start;
  }

  .contact-modal-icon {
    flex-shrink: 0;
    width: 2rem;
    display: flex;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--muted);
    font-weight: 300;
    transition: color 0.2s;
  }

  .contact-modal-label {
    font-family: "Inter", sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #475569;
  }

  .contact-modal-value {
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    color: var(--text);
    font-weight: 700;
    letter-spacing: -0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .contact-modal-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .contact-modal-copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: 1px solid #475569;
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 1rem;
  }

  .contact-modal-copy-btn .material-symbols-outlined {
    font-size: 1rem;
  }

  .contact-modal-copy-btn:hover {
    border-color: var(--text);
    color: var(--text);
  }

  .contact-modal-url-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 0.9rem;
    background: #ffffff;
    color: #000000;
    font-family: "Inter", sans-serif;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
  }

  .contact-modal-url-btn:hover {
    background: #f9f506;
    color: #000;
  }

  .contact-modal-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 3.5rem 0;
  }

  .contact-modal-divider::before,
  .contact-modal-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: rgba(30, 41, 59, 0.6);
  }

  .contact-modal-divider-text {
    font-family: "Inter", sans-serif;
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #475569;
    white-space: nowrap;
  }

  .contact-modal-brief-btn {
    display: block;
    width: 100%;
    padding: 1.5rem 2rem;
    background: #f9f506;
    border: none;
    color: #000;
    text-align: center;
    font-family: "Inter", sans-serif;
    font-size: 1.125rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 2px 2px 0px 0px #2E5BFF;
  }

  .contact-modal-brief-btn:hover {
    background: #fffb00;
  }

  .contact-modal-brief-btn:active {
    transform: translateY(1px);
  }

  @media (max-width: 520px) {
    .contact-modal-content {
      padding: 1.85rem 1.15rem 1.25rem;
      width: calc(100% - 2rem);
      max-height: calc(100svh - 2rem);
      overflow-y: auto;
    }

    .contact-modal-close {
      top: 1.75rem;
      right: 1.75rem;
    }

    .contact-modal-status {
      margin-bottom: 0.85rem;
    }

    .contact-modal-title {
      font-size: clamp(1.7rem, 8.6vw, 2.45rem);
      line-height: 0.84;
      margin: 0 0 0.9rem;
    }

    .contact-modal-title br {
      display: none;
    }

    .contact-modal-brief-btn {
      padding: 0.75rem 1.125rem;
      font-size: 0.99rem;
      letter-spacing: 0.13em;
      box-shadow: 1px 1px 0px 0px #2E5BFF;
      margin: 0.6rem 0;
    }

    .contact-modal-divider {
      margin: 1rem 0;
      gap: 0.75rem;
    }

    .contact-modal-divider-text {
      font-size: 0.55rem;
      letter-spacing: 0.13em;
    }

    .contact-modal-row {
      flex-wrap: wrap;
      align-items: flex-start;
      padding: 0.75rem 0;
      gap: 0.85rem;
    }

    .contact-modal-row-left {
      flex: 1 1 100%;
      gap: 0.85rem;
    }

    .contact-modal-actions {
      width: 100%;
      justify-content: flex-start;
      min-width: 0;
    }

    .contact-modal-label {
      font-size: 0.55rem;
    }

    .contact-modal-value {
      font-size: 0.95rem;
    }

    .contact-modal-copy-btn {
      width: 2.1rem;
      height: 2.1rem;
    }

    .contact-modal-icon {
      width: 1.6rem;
      font-size: 1.35rem;
    }

    .contact-modal-url-btn {
      flex: 0 0 auto;
      min-width: 0;
      padding: 0.5rem 0.75rem;
      font-size: 0.66rem;
      letter-spacing: 0.07em;
    }
  }

  .pricing-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .pricing-card-price {
    font-family: "Space Grotesk", "Manrope", monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #a1a1aa;
    text-align: right;
    white-space: nowrap;
  }

  .intro-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    padding: 6rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
    align-items: center;
    scroll-margin-top: 6rem;
  }

  @media (min-width: 1024px) {
    .intro-section {
      grid-template-columns: 7fr 5fr;
      padding: 10rem 1.5rem;
    }
  }

  .intro-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .intro-title {
    font-size: clamp(2.625rem, 8.25vw, 5.25rem);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 0.9;
    letter-spacing: -0.04em;
    margin: 0 0 3rem 0;
    color: #ffffff;
    font-family: "Inter", sans-serif;
  }

  .intro-text {
    font-size: clamp(1.125rem, 2.25vw, 1.6875rem);
    color: #6b7280;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    font-family: "Manrope", sans-serif;
    max-width: none;
  }

  .intro-highlight {
    color: #ffffff;
    font-weight: 900;
  }

  .intro-text strong {
    color: #ffffff;
    font-weight: 900;
  }

  .intro-photo-wrap {
    width: 100%;
    max-width: 28rem;
    aspect-ratio: 1/1;
    border-radius: 0;
    overflow: hidden;
    border: none;
    box-shadow: none;
    justify-self: center;
    margin: 0;
    background: #000000;
  }

  @media (min-width: 1024px) {
    .intro-photo-wrap {
      justify-self: end;
    }
  }

  .intro-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  .services-section {
    padding-block: 0.5rem 0.5rem;
    max-width: 1280px;
    margin-inline: auto;
    scroll-margin-top: 6rem;
  }

  .services-title {
    margin: 0 0 0.5rem;
    font-size: clamp(1.875rem, 5.25vw, 3.75rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--text);
    font-family: "Inter", sans-serif;
    text-align: left;
  }

  .services-columns-wrapper {
    display: flex;
    justify-content: flex-start;
    padding-bottom: 1.5rem;
  }

  .see-portfolio-wrap {
    display: flex;
    justify-content: flex-start;
    padding-top: 0;
    padding-bottom: 1.5rem;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .services-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(4rem, 8vw, 8rem);
    width: 100%;
  }

  .services-column {
    padding: 0;
  }

  .services-column h3 {
    margin: 0 0 clamp(1.5rem, 3vw, 2rem);
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--muted);
    font-family: "Manrope", sans-serif;
    white-space: nowrap;
  }

  .services-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 2.5vw, 2rem);
  }

  .services-list li {
    color: var(--text);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    font-family: "Manrope", sans-serif;
    display: flex;
    align-items: center;
  }

  .bullet {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    margin-right: 2rem;
    flex-shrink: 0;
  }

  .bullet-orange {
    background-color: #f97316;
  }
  .bullet-purple {
    background-color: #8b5cf6;
  }
  .bullet-blue {
    background-color: #3b82f6;
  }
  .bullet-green {
    background-color: #10b981;
  }
  .bullet-pink {
    background-color: #ec4899;
  }
  .bullet-cyan {
    background-color: #06b6d4;
  }

  .services-chip-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 1.5vw, 1.5rem);
  }

  .services-chip-list li {
    display: inline-flex;
    align-items: center;
    border: 2px solid var(--line);
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    font-size: clamp(1.125rem, 1.75vw, 1.25rem);
    font-weight: 700;
    color: var(--text);
    font-family: "Inter", sans-serif;
    background: transparent;
  }

  /* Hamburger Menu Button */
  .hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    gap: 6px;
    z-index: 60;
  }

  .hamburger-line {
    display: block;
    width: 28px;
    height: 2.5px;
    background-color: var(--text);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(6px, 6px);
  }

  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  /* Mobile Menu Overlay */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    background: color-mix(in oklab, var(--bg) 95%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity 0.3s ease,
      visibility 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu[aria-hidden="false"] {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-content {
    position: relative;
    width: 100%;
    max-width: 400px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .mobile-menu-close {
    position: absolute;
    top: -3rem;
    right: 1rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--text);
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .mobile-menu-close:hover {
    color: #3b82f6;
  }

  .mobile-menu-brand {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    color: var(--text);
    margin-bottom: 3rem;
  }

  .mobile-menu-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .mobile-menu-link {
    font-size: clamp(2rem, 8vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s ease;
    font-family: "Inter", sans-serif;
    text-align: center;
    line-height: 1;
    white-space: nowrap;
  }

  @media (max-width: 420px) {
    .mobile-menu-link {
      font-size: clamp(1.6rem, 7.2vw, 2.2rem);
      letter-spacing: 0.03em;
    }
  }

  .mobile-menu-link:hover {
    color: #3b82f6;
  }

  /* Switch to hamburger at tablet and below */
  @media (max-width: 1023px) {
    .site-nav nav:not(.mobile-menu-nav),
    .top-cta {
      display: none;
    }

    .hamburger-btn {
      display: flex;
    }

    .tech-tile[data-category="empty"] {
      display: none;
    }

    .stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-ticker {
      margin-block: 1.5rem 1rem;
    }

    .intro-section {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding: 4rem 1rem;
    }

    .intro-title {
      font-size: clamp(2.25rem, 7.5vw, 3.75rem);
      margin-bottom: 2rem;
    }

    .intro-text {
      font-size: clamp(0.9375rem, 3vw, 1.3125rem);
    }

    .intro-photo-wrap {
      max-width: 20rem;
      justify-self: center;
    }

    .services-columns {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .services-title {
      font-size: clamp(2.5rem, 10vw, 4rem);
      text-align: left;
    }

    .services-list {
      gap: 1.5rem;
    }

    .services-list li {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .services-chip-list {
      gap: 0.75rem;
    }

    .services-chip-list li {
      padding: 0.75rem 1.25rem;
      font-size: clamp(1rem, 4vw, 1.25rem);
    }
  }

  @media (max-width: 640px) {
    .footer-links {
      gap: 1.5rem;
      flex-wrap: nowrap;
    }
  }

  /* Scroll to Top Button */
  .scroll-to-top {
    display: none;
    position: fixed;
    bottom: 5rem;
    right: 1.5rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--text);
    cursor: pointer;
    z-index: 60;
    align-items: center;
    justify-content: center;
    transition:
      opacity 0.3s ease,
      transform 0.2s ease,
      bottom 0.3s ease;
  }

  @media (min-width: 761px) {
    .scroll-to-top {
      bottom: 7rem;
    }
  }

  .scroll-to-top:hover {
    background: var(--surface-soft);
    transform: translateY(-2px);
  }

  .scroll-to-top.visible {
    display: flex;
  }

  .scroll-to-top.footer-visible {
    bottom: 7rem;
  }

  @media (min-width: 761px) {
    .scroll-to-top.footer-visible {
      bottom: 9rem;
    }
  }

  @media (max-width: 760px) {
    .scroll-to-top.visible {
      display: flex;
    }
  }

  @media (min-width: 761px) {
    .scroll-to-top {
      display: none !important;
    }
  }

  /* Who I Work With - Simplified */
  .who-i-work-with-section {
    padding-block: clamp(4rem, 8vw, 7rem);
    max-width: 1280px;
    margin-inline: auto;
    border-top: 1px solid var(--line);
  }

  .who-i-work-with-title {
    font-size: clamp(1.875rem, 5.25vw, 3.75rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 0.25rem 0;
    color: #ffffff;
    font-family: "Inter", sans-serif;
  }

  .who-i-work-with-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wiw-card {
    --wiw-accent: #ff00ff;
    --wiw-bg: #6366f1;
    position: relative;
    border-radius: 0;
    display: flex;
    flex-direction: row;
    gap: 2rem;
    background: #000000;
    overflow: hidden;
    transition: transform 0.15s ease;
    padding: 1.5rem;
  }

  .wiw-card-left {
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .wiw-card-right {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    flex: 1;
  }

  @media (max-width: 760px) {
    .wiw-card {
      flex-direction: column;
      gap: 1.25rem;
      padding: 1rem;
    }

    .wiw-card-left {
      align-items: flex-start;
    }

    .wiw-card-right {
      align-items: flex-start;
    }
  }

  .wiw-card:hover {
    transform: translate(-2px, -2px);
  }

  .wiw-card--founders {
    --wiw-accent: #ff00ff;
    --wiw-bg: #6366f1;
  }

  .wiw-card--solopreneurs {
    --wiw-accent: #00ffff;
    --wiw-bg: #10b981;
  }

  .wiw-card-visual {
    position: relative;
    width: 250px;
    height: 40px;
    background: var(--wiw-bg);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 0;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }

  .wiw-ascii-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .wiw-ascii-layer {
    position: absolute;
    top: 50%;
    left: 50%;
    width: max-content;
    margin: 0;
    padding: 0;
    font-family: monospace;
    font-size: clamp(0.125rem, 0.25vw, 0.22rem);
    line-height: 1.1;
    white-space: pre;
    overflow: hidden;
    pointer-events: none;
    display: block;
  }

  .wiw-ascii-layer::before,
  .wiw-ascii-layer::after {
    display: none;
  }

  .wiw-ascii-layer--back {
    color: rgba(255, 255, 255, 0.06);
    transform: translate(calc(-50% + 6px), calc(-50% + 6px)) scale(1.04);
    filter: blur(1.5px);
  }

  .wiw-ascii-layer--mid {
    color: rgba(255, 255, 255, 0.12);
    transform: translate(calc(-50% + 3px), calc(-50% + 3px)) scale(1.02);
    filter: blur(0.5px);
  }

  .wiw-ascii-layer--front {
    color: rgba(255, 255, 255, 0.35);
    transform: translate(-50%, -50%);
  }

  .wiw-card-tag {
    background: rgba(0, 0, 0, 0.8);
    padding: 0.5rem 1rem;
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.9);
    font-family: "Inter", sans-serif;
  }

  .wiw-card-metric {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .wiw-card-metric-value {
    font-size: clamp(1.265rem, 2.25vw, 1.6875rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    line-height: 1;
    color: #ffffff;
    font-family: "Inter", sans-serif;
  }

  .wiw-card-metric-subtitle {
    font-size: clamp(0.5625rem, 1.125vw, 0.84375rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    font-family: "Inter", sans-serif;
  }

  .wiw-card-content {
    padding: 0;
  }

  .wiw-card-text {
    margin: 0;
    display: grid;
    gap: 0.75rem;
    color: #6b7280;
    font-size: clamp(1.125rem, 2.25vw, 1.6875rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-family: "Manrope", sans-serif;
    max-width: 56ch;
  }

  .wiw-card-text span {
    display: block;
  }

  .wiw-card-text strong {
    color: #ffffff;
    font-weight: 900;
  }

  .wiw-card-btn {
    display: inline-block;
    align-self: flex-start;
    padding: 1rem 2rem;
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #000000;
    background-color: #ffffff;
    border: none;
    border-radius: 0;
    cursor: pointer;
    transition: all 150ms cubic-bezier(0.4, 0, 0.2, 1);
    text-align: center;
    text-decoration: none;
    font-family: "Inter", sans-serif;
    margin-top: auto;
  }

  .wiw-card-btn:hover {
    background-color: #ffff00;
    color: #000000;
    text-decoration: none;
  }

  .wiw-card-ascii-canvas {
    width: 250px;
    height: 200px;
    margin: 0;
    display: block;
    z-index: 10;
    background: transparent;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Tech Stack Section */
  .tech-stack-section {
    padding-block: clamp(4rem, 8vw, 7rem);
    max-width: 1280px;
    margin-inline: auto;
    border-top: 1px solid var(--line);
  }

  .tech-stack-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 1;
    margin: 0 0 2rem 0;
    color: #ffffff;
    font-family: "Inter", sans-serif;
  }

  .tech-stack-search-wrapper {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .tech-stack-search {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 4px solid rgba(255, 255, 255, 0.2);
    padding: 1.25rem 0;
    font-size: clamp(1.25rem, 3vw, 2rem);
    font-weight: 900;
    text-transform: uppercase;
    color: #ffffff;
    font-family: "Inter", sans-serif;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .tech-stack-search::placeholder {
    color: rgba(255, 255, 255, 0.1);
  }

  .tech-stack-search:focus {
    border-bottom-color: #ffff00;
  }

  .tech-filter-capsules {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .tech-filter-capsule {
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: rgba(255, 255, 255, 0.45);
    font-family: "Inter", sans-serif;
    font-size: 0.6rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.18s ease;
    line-height: 1.6;
  }

  .tech-filter-capsule:hover {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.5);
  }

  /* All (white) */
  .tech-filter-capsule--all.active,
  .tech-filter-capsule--all:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #000000;
  }

  /* Category accent colors — idle tint + active fill */
  .tech-filter-capsule--frontend {
    border-color: rgba(129, 140, 248, 0.4);
    color: rgba(129, 140, 248, 0.6);
  }
  .tech-filter-capsule--frontend.active,
  .tech-filter-capsule--frontend:hover {
    background: #818cf8;
    border-color: #818cf8;
    color: #000;
  }

  .tech-filter-capsule--mobile {
    border-color: rgba(6, 182, 212, 0.4);
    color: rgba(6, 182, 212, 0.6);
  }
  .tech-filter-capsule--mobile.active,
  .tech-filter-capsule--mobile:hover {
    background: #06b6d4;
    border-color: #06b6d4;
    color: #000;
  }

  .tech-filter-capsule--backend {
    border-color: rgba(245, 158, 11, 0.4);
