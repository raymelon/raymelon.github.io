---
import { Image } from 'astro:assets';
import Layout from "../layouts/Layout.astro";
import ImageTicker from "../components/ImageTicker.astro";
import MediaCarousel from "../components/MediaCarousel.astro";
import {
  assertInclusionParity,
  getAllProjects,
  getGroupDeckModels,
  getPortfolioContent,
  getPortfolioAssetUrl,
} from "../lib/portfolio";

import heroSource from '../assets/P_20200702_131755_mod.jpg';
import introSource from '../assets/syncsignature-headshot-1706457210445 (3).png';
import shipSource from '../assets/P_20181107_210050.jpg';

const { ctaSlide } = getPortfolioContent();
const allProjects = getAllProjects();
const groupDecks = getGroupDeckModels(allProjects);
const groupGridCards = [...groupDecks];
while (groupGridCards.length < 9) {
  groupGridCards.push(null as never);
}
const renderedHomeEntities = groupDecks.reduce(
  (total, group) => total + group.projects.length,
  0,
);
assertInclusionParity(renderedHomeEntities, "home group-grid render");
const contactUrl = ctaSlide?.url ?? "https://x.com/pseudokid";
