<script>
  // Testimonial ASCII renderer (grayscale with color tint overlay)
  (function () {
    const INDIGO = { r: 99, g: 102, b: 241 };
    const GREEN = { r: 34, g: 197, b: 94 };
    const CRIMSON = { r: 220, g: 38, b: 38 };

    function renderTestimonialASCII(
      canvasId: string,
      imgId: string,
      _color: { r: number; g: number; b: number },
      initials: string,
    ) {
      const canvas = document.getElementById(canvasId) as HTMLCanvasElement;
      const img = document.getElementById(imgId) as HTMLImageElement;
      if (!canvas || !img) return;

      const CHAR_SET = " .,:;ox%#@";
      const WHITE = { r: 255, g: 255, b: 255 };
      const BLACK = { r: 0, g: 0, b: 0 };

      function lerp(a: number, b: number, t: number) {
        return a + (b - a) * t;
      }

      function doRender() {
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const wrap = canvas.parentElement;
        if (!wrap) return;

        const dpr = window.devicePixelRatio || 1;
        const wrapW = wrap.clientWidth;
        const wrapH = wrap.clientHeight;

        const fontSize = Math.max(2.4, Math.min(5, wrapW / 36));
        const charW = fontSize * 0.4;
        const charH = fontSize * 0.8;

        const cols = Math.floor(wrapW / charW);
        const rows = Math.floor(wrapH / charH);

        canvas.width = wrapW * dpr;
        canvas.height = wrapH * dpr;
        canvas.style.width = wrapW + "px";
        canvas.style.height = wrapH + "px";
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.scale(dpr, dpr);

        const offscreen = document.createElement("canvas");
        offscreen.width = cols;
        offscreen.height = rows;
        const offCtx = offscreen.getContext("2d");
        if (!offCtx) return;

        offCtx.drawImage(img, 0, 0, cols, rows);
        const imageData = offCtx.getImageData(0, 0, cols, rows);
        const pixels = imageData.data;

        function samplePixel(x: number, y: number) {
          const i = (y * cols + x) * 4;
          return { r: pixels[i], g: pixels[i + 1], b: pixels[i + 2] };
        }

        const cornerSamples = [
          samplePixel(0, 0),
          samplePixel(cols - 1, 0),
          samplePixel(0, rows - 1),
          samplePixel(cols - 1, rows - 1),
        ];
        const bg = cornerSamples.reduce(
          (acc, c) => ({ r: acc.r + c.r, g: acc.g + c.g, b: acc.b + c.b }),
          { r: 0, g: 0, b: 0 },
        );
        bg.r /= cornerSamples.length;
        bg.g /= cornerSamples.length;
        bg.b /= cornerSamples.length;

        const bgThreshold = 18;

        ctx.fillStyle = "#000000";
        ctx.fillRect(0, 0, wrapW, wrapH);

        ctx.font = `${fontSize}px "Courier New", monospace`;
        ctx.textBaseline = "top";

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            const idx = (row * cols + col) * 4;
            const r = pixels[idx];
            const g = pixels[idx + 1];
            const b = pixels[idx + 2];

            const brightness = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
            const tone = Math.pow(brightness, 0.6);

            if (tone < 0.16) continue;

            const dr = r - bg.r;
            const dg = g - bg.g;
            const db = b - bg.b;
            const bgDist = Math.sqrt(dr * dr + dg * dg + db * db);
            if (bgDist < bgThreshold) continue;

            const charIdx = Math.floor((1 - tone) * (CHAR_SET.length - 1));
            const char = CHAR_SET[charIdx];

            const cr = Math.round(lerp(BLACK.r, WHITE.r, tone));
            const cg = Math.round(lerp(BLACK.g, WHITE.g, tone));
            const cb = Math.round(lerp(BLACK.b, WHITE.b, tone));

            const maxC = Math.max(r, g, b);
            const minC = Math.min(r, g, b);
            const satRange = maxC - minC;
            if (brightness > 0.96 && satRange < 45) continue;

            const alpha = 0.85 * Math.min(1, Math.max(0, (tone - 0.14) / 0.75));

            ctx.fillStyle = `rgba(${cr}, ${cg}, ${cb}, ${alpha})`;
            ctx.fillText(char, col * charW, row * charH);
          }
        }

        // Render initials as ASCII overlay in center
        // For 64x64px avatars, use a larger fixed font size relative to canvas
        const initFontSize = Math.min(wrapW, wrapH) * 0.45;
        ctx.font = `900 ${initFontSize}px "Inter", sans-serif`;
        ctx.textBaseline = "middle";
        ctx.textAlign = "center";

        // Draw shadow/outline for contrast
        const centerX = wrapW / 2;
        const centerY = wrapH / 2;

        ctx.fillStyle = "rgba(0, 0, 0, 0.7)";
        for (let dx = -1; dx <= 1; dx++) {
          for (let dy = -1; dy <= 1; dy++) {
            ctx.fillText(initials, centerX + dx, centerY + dy);
          }
        }

        // Draw main initials in white
        ctx.fillStyle = "rgba(255, 255, 255, 0.95)";
        ctx.fillText(initials, centerX, centerY);
      }

      function triggerRender() {
        if (img.complete && img.naturalWidth > 0) {
          doRender();
        } else {
          img.addEventListener("load", doRender, { once: true });
