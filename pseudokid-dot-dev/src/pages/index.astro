<script>
  // Quick Wins Carousel — infinite loop
  const quickWinsCarousel = document.querySelector(".quick-wins-carousel");
  if (quickWinsCarousel) {
    const track = quickWinsCarousel.querySelector(
      ".quick-wins-track",
    ) as HTMLElement;
    const dotsContainer = quickWinsCarousel.querySelector(
      ".quick-wins-dots",
    ) as HTMLElement;
    const prevBtn = quickWinsCarousel.querySelector(
      ".quick-wins-prev",
    ) as HTMLButtonElement;
    const nextBtn = quickWinsCarousel.querySelector(
      ".quick-wins-next",
    ) as HTMLButtonElement;
    const cards = Array.from(
      track.querySelectorAll(".quick-win-card"),
    ) as HTMLElement[];

    let currentPage = 0;
    let cardsPerPage = 3;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function getCardsPerPage() {
      if (window.innerWidth <= 640) return 1;
      if (window.innerWidth <= 1040) return 2;
      return 3;
    }

    function getTotalPages() {
      return Math.ceil(cards.length / cardsPerPage);
    }

    function buildDots() {
      dotsContainer.innerHTML = "";
      const total = getTotalPages();
      for (let i = 0; i < total; i++) {
        const dot = document.createElement("button");
        dot.className = "quick-wins-dot" + (i === currentPage ? " active" : "");
        dot.setAttribute("aria-label", `Go to page ${i + 1}`);
        dot.addEventListener("click", () => {
          stopAuto();
          goToPage(i);
          startAuto();
        });
        dotsContainer.appendChild(dot);
      }
    }

    function updateVisibility() {
      const start = currentPage * cardsPerPage;
      const end = start + cardsPerPage;
      cards.forEach((card, i) => {
        const isVisible = i >= start && i < end;
        if (!isVisible) {
          card.classList.remove("is-visible");
          card.style.display = "none";
          return;
        }

        card.style.display = "";
        // Trigger a subtle fade-in on each page change
        requestAnimationFrame(() => {
          card.classList.add("is-visible");
        });
      });
      dotsContainer.querySelectorAll(".quick-wins-dot").forEach((dot, i) => {
        dot.classList.toggle("active", i === currentPage);
      });
    }

    function goToPage(page: number) {
      const total = Math.max(1, getTotalPages());
      currentPage = ((page % total) + total) % total;
      updateVisibility();
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(() => {
        goToPage(currentPage + 1);
      }, 4000);
    }

    function stopAuto() {
      if (autoTimer !== null) {
        clearInterval(autoTimer);
        autoTimer = null;
      }
    }

    prevBtn.addEventListener("click", () => {
      stopAuto();
      goToPage(currentPage - 1);
      startAuto();
    });

    nextBtn.addEventListener("click", () => {
      stopAuto();
      goToPage(currentPage + 1);
      startAuto();
    });

    function init() {
      cardsPerPage = getCardsPerPage();
      currentPage = 0;
      buildDots();
      updateVisibility();
      startAuto();
    }

    init();
    window.addEventListener("resize", () => {
      const newCpp = getCardsPerPage();
      if (newCpp !== cardsPerPage) {
        cardsPerPage = newCpp;
        currentPage = 0;
        buildDots();
        updateVisibility();
      }
    });
  }
</script>

