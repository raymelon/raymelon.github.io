---
import Layout from '../../layouts/Layout.astro';
import MediaCarousel from '../../components/MediaCarousel.astro';
import MediaMasonry from '../../components/MediaMasonry.astro';
import {
  assertInclusionParity,
  getAllProjects,
  getPortfolioContent,
  getProjectAssets,
  getProjectGroup,
  getProjectMetricItems,
  getProjectSlug,
  getProjectTheme,
  getStatusLabel,
  usesMasonryMediaLayout
} from '../../lib/portfolio';

export function getStaticPaths() {
  const projects = getAllProjects();
  assertInclusionParity(projects.length, 'brief routes');

  return projects.map((project) => ({
    params: { slug: getProjectSlug(project) },
    props: { project }
  }));
}

const { project } = Astro.props;
const { ctaSlide } = getPortfolioContent();
const group = getProjectGroup(project);
const theme = getProjectTheme(project);
const assets = getProjectAssets(project);
const statusLabel = getStatusLabel(project.status);
const metricItems = getProjectMetricItems(project);
const contactUrl = ctaSlide?.url ?? 'https://x.com/pseudokid';
const hasMedia = assets.length > 0;
const hasYear = Boolean(project.year?.trim());
const useMasonry = usesMasonryMediaLayout(project.name);
const fallbackDeckHref = `/deck/${group.id}`;
---

<Layout title={`${project.name} | pseudokid.dev`} description={project.description ?? project.tagline ?? 'Product brief'}>
  <nav class="site-nav compact">
    <div>
      <a href="/#top" class="brand-link">
        <div class="brand-text">
          pseudokid<span class="brand-dot">.</span>dev
        </div>
      </a>

      <nav>
        <a href="/#about">About</a>
        <a href="/#who-i-work-with">Who I Work With</a>
        <a href="/#what-i-build">Services</a>
        <a href="/#portfolio">Portfolio</a>
        <a href="/#pricing">Pricing</a>
      </nav>

      <button class="top-cta" id="header-contact-btn">Contact</button>

      <button
        class="hamburger-btn"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </nav>

  <div class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-content">
      <a href="/#top" class="mobile-menu-brand">
        pseudokid<span class="brand-dot">.</span>dev
      </a>
      <button class="mobile-menu-close" aria-label="Close menu">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <nav class="mobile-menu-nav">
        <a href="/#about" class="mobile-menu-link">About</a>
        <a href="/#who-i-work-with" class="mobile-menu-link">Who I Work With</a>
        <a href="/#what-i-build" class="mobile-menu-link">Services</a>
        <a href="/#portfolio" class="mobile-menu-link">Portfolio</a>
        <a href="/#pricing" class="mobile-menu-link">Pricing</a>
        <button class="mobile-menu-link" id="mobile-contact-btn">Contact</button>
      </nav>
    </div>
  </div>

  <main class="brief-overlay" style={`--card:${theme.card};--tint:${theme.tint};--accent:${theme.accent};--surface:${theme.surface};`}>
    <div class="brief-backdrop" aria-hidden="true"></div>

    <div class="brief-page" role="dialog" aria-modal="true" aria-label={`${project.name} brief`}>
      <a class="back-link" href={fallbackDeckHref} data-history-back>Back to project deck</a>

    <section class="brief-hero">
      <div>
        <p class="group-pill">{group.title}</p>
        <h1>{project.name}</h1>
        <p class="tagline">{project.tagline ?? project.description ?? 'Product brief from portfolio studio.'}</p>
      </div>

      <dl class="meta-grid">
        {hasYear ? (
          <div>
            <dt>Year</dt>
            <dd>{project.year}</dd>
          </div>
        ) : null}
        <div>
          <dt>Project deck</dt>
          <dd>{group.title}</dd>
        </div>
      </dl>
    </section>

    {metricItems.length > 0 ? (
      <section class="metric-panel" aria-label={`${project.name} metrics`}>
        {metricItems.map((item) => (
          <article class="metric-card">
            {item.value ? <p class="metric-card-value">{item.value}</p> : null}
            <p class="metric-card-label">{item.label}</p>
          </article>
        ))}
      </section>
    ) : null}

    <section class={`brief-body ${hasMedia ? 'has-media' : 'no-media'} ${hasMedia ? (useMasonry ? 'media-vertical' : 'media-horizontal') : ''}`}>
      <article class="brief-copy">
        <h2>The Brief</h2>
        <p>
          {project.description ?? project.tagline ??
            'A practical product exploration focused on real user outcomes, lean delivery, and measurable momentum.'}
        </p>

        <div class="actions">
          {project.url ? (
            <a href={project.url} target="_blank" rel="noreferrer noopener">Visit project</a>
          ) : null}
          <button class="brief-contact-btn" id="brief-contact-btn">Get in touch</button>
        </div>
      </article>

       {hasMedia ? (
        <article class="brief-media">
          <h2>Media</h2>

          <div class="brief-carousel-shell">
            {useMasonry ? (
              <MediaMasonry assets={assets} projectName={project.name} label={`${project.name} media masonry`} videoControls={true} />
            ) : (
              <MediaCarousel
                assets={assets}
                projectName={project.name}
                label={`${project.name} media carousel`}
                showControls={assets.length > 1}
                videoControls={true}
              />
            )}
          </div>
        </article>
      ) : null}
    </section>
    </div>
  </main>

  <div class="contact-modal" id="brief-contact-modal">
    <div class="contact-modal-backdrop" id="brief-contact-modal-backdrop"></div>
    <div class="contact-modal-content">
      <button class="contact-modal-close" id="brief-contact-modal-close">
        <span class="material-symbols-outlined">close</span>
      </button>
      <div class="contact-modal-status">
        <span class="status-dot"></span>
        <span>Available for new projects</span>
      </div>
      <h3 class="contact-modal-title">get in<br/>touch</h3>
      <button
        class="contact-modal-brief-btn"
        data-tally-open="jaBv6Y"
        data-tally-layout="modal"
        data-tally-width="800"
        data-tally-align-left="1"
        data-tally-overlay="1"
        data-tally-form-events-forwarding="1"
       >
         Open Inquiry Form
      </button>
      <div class="contact-modal-divider">
        <span class="contact-modal-divider-text">or, contact directly</span>
      </div>
      <div class="contact-modal-list">
        <div class="contact-modal-row">
          <div class="contact-modal-row-left">
            <span class="material-symbols-outlined contact-modal-icon">mail</span>
            <div class="contact-modal-info">
              <span class="contact-modal-label">Email</span>
              <span class="contact-modal-value">raymel@pseudokid.dev</span>
            </div>
          </div>
          <div class="contact-modal-actions">
            <button class="contact-modal-copy-btn contact-modal-copy-icon" title="Copy">
              <span class="material-symbols-outlined">content_copy</span>
            </button>
            <a class="contact-modal-url-btn" href="mailto:raymel@pseudokid.dev" target="_blank" rel="noreferrer noopener">Send Email</a>
          </div>
        </div>
        <div class="contact-modal-row">
          <div class="contact-modal-row-left">
            <span class="material-symbols-outlined contact-modal-icon">work</span>
            <div class="contact-modal-info">
              <span class="contact-modal-label">LinkedIn</span>
              <span class="contact-modal-value">raymelfrancisco</span>
            </div>
          </div>
          <div class="contact-modal-actions">
            <button class="contact-modal-copy-btn contact-modal-copy-icon" title="Copy">
              <span class="material-symbols-outlined">content_copy</span>
            </button>
            <a class="contact-modal-url-btn" href="https://www.linkedin.com/messaging/compose/?recipient=raymelfrancisco" target="_blank" rel="noreferrer noopener">Send DM</a>
          </div>
        </div>
        <div class="contact-modal-row">
          <div class="contact-modal-row-left">
            <span class="material-symbols-outlined contact-modal-icon">alternate_email</span>
            <div class="contact-modal-info">
              <span class="contact-modal-label">X / Twitter</span>
              <span class="contact-modal-value">@pseudokid</span>
            </div>
          </div>
          <div class="contact-modal-actions">
            <button class="contact-modal-copy-btn contact-modal-copy-icon" title="Copy">
              <span class="material-symbols-outlined">content_copy</span>
            </button>
            <a class="contact-modal-url-btn" href="https://x.com/messages/compose?recipient_id=1698759945129541632" target="_blank" rel="noreferrer noopener">Send DM</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="site-footer" aria-hidden="true" aria-label="Footer navigation">
    <div class="footer-content">
      <div class="footer-status">
        <span class="status-dot"></span>
        <span>Available for new projects</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/raymelon" target="_blank" rel="noreferrer noopener">GitHub</a>
        <a href="https://www.linkedin.com/in/raymelfrancisco/" target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a href="https://x.com/pseudokid" target="_blank" rel="noreferrer noopener">X/Twitter</a>
        <a href="mailto:raymel@pseudokid.dev">Email</a>
      </div>
    </div>
  </footer>

  <footer class="site-footer-embedded" aria-label="Site footer">
    <div class="footer-embedded-content">
      <div class="footer-brand-col">
        <a href="/#top" class="footer-brand-link">
          <div class="brand-text">
            pseudokid<span class="brand-dot">.</span>dev
          </div>
        </a>
        <div class="footer-status footer-embedded-status">
          <span class="status-dot"></span>
          <span>Available for new projects</span>
        </div>
      </div>
      <div class="footer-right-col">
        <div class="footer-links">
          <a href="https://github.com/raymelon" target="_blank" rel="noreferrer noopener">GitHub</a>
          <a href="https://www.linkedin.com/in/raymelfrancisco/" target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a href="https://x.com/pseudokid" target="_blank" rel="noreferrer noopener">X/Twitter</a>
          <a href="mailto:raymel@pseudokid.dev">Email</a>
        </div>
        <div class="footer-built-with">
          <span>Built with Astro</span><span class="fbw-sep">&nbsp;•&nbsp;</span><wbr/><span>Birthed with OpenCode</span><span class="fbw-sep">&nbsp;•&nbsp;</span><wbr /><span>Stitched with Stitch</span><span class="fbw-sep">&nbsp;•&nbsp;</span><wbr /><span>© 2026</span>
        </div>
      </div>
    </div>
  </footer>

  <button class="scroll-to-top" aria-label="Scroll to top" hidden>
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="18,15 12,9 6,15"></polyline>
    </svg>
  </button>
</Layout>

<script is:inline>
  (() => {
    const fallbackHref =
      document.querySelector('.back-link')?.getAttribute('href') ?? '/';

    const goBack = () => {
      const fromSameSite = document.referrer && new URL(document.referrer).origin === window.location.origin;
      if (fromSameSite) {
        window.history.back();
        return;
      }

      window.location.assign(fallbackHref);
    };

    const handles = document.querySelectorAll('[data-history-back]');
    handles.forEach((handle) => {
      handle.addEventListener('click', (event) => {
        if (!(event instanceof MouseEvent)) {
          return;
        }

        event.preventDefault();
        goBack();
      });
    });
  })();

  // Mobile menu functionality
  const hamburgerBtn = document.querySelector('.hamburger-btn');
  const mobileMenu = document.querySelector('.mobile-menu');
  const mobileMenuClose = document.querySelector('.mobile-menu-close');
  const mobileMenuLinks = document.querySelectorAll('.mobile-menu-link');

  function openMobileMenu() {
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeMobileMenu() {
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  }

  if (hamburgerBtn) {
    hamburgerBtn.addEventListener('click', () => {
      const isExpanded = hamburgerBtn.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMobileMenu();
      } else {
        openMobileMenu();
      }
    });
  }

  if (mobileMenuClose) {
    mobileMenuClose.addEventListener('click', closeMobileMenu);
  }

  mobileMenuLinks.forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Close menu when clicking on brand logo
  const mobileMenuBrand = document.querySelector('.mobile-menu-brand');
  if (mobileMenuBrand) {
    mobileMenuBrand.addEventListener('click', closeMobileMenu);
  }

  if (mobileMenu) {
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMobileMenu();
      }
    });
  }

  document.addEventListener('keydown', (e) => {
    if (
      e.key === 'Escape' &&
      mobileMenu?.getAttribute('aria-hidden') === 'false'
    ) {
      closeMobileMenu();
    }
  });

  // Handle mobile contact button - opens modal and closes menu
  const mobileContactBtn = document.getElementById('mobile-contact-btn');
  if (mobileContactBtn) {
    mobileContactBtn.addEventListener('click', () => {
      closeMobileMenu();
      const contactModal = document.getElementById('brief-contact-modal');
      if (contactModal) {
        contactModal.classList.add('active');
        document.body.style.overflow = 'hidden';
      }
    });
  }

  // Scroll handler for floating footer
  const footer = document.querySelector('.site-footer');
  const embeddedFooter = document.querySelector('.site-footer-embedded');

  function handleScroll() {
    // Check if we're near the bottom (within 100px of the embedded footer)
    const embeddedFooterRect = embeddedFooter?.getBoundingClientRect();
    const isNearBottom = embeddedFooterRect && embeddedFooterRect.top < window.innerHeight + 100;

    // Show floating footer always, except when near bottom
    if (!isNearBottom) {
      footer?.classList.add('visible');
      footer?.setAttribute('aria-hidden', 'false');
    } else {
      footer?.classList.remove('visible');
      footer?.setAttribute('aria-hidden', 'true');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Scroll to Top Button functionality
  const scrollToTopBtn = document.querySelector('.scroll-to-top');

  if (scrollToTopBtn) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 300) {
        scrollToTopBtn.classList.add('visible');
        scrollToTopBtn.removeAttribute('hidden');
      } else {
        scrollToTopBtn.classList.remove('visible');
        scrollToTopBtn.setAttribute('hidden', 'true');
      }

      // Move scroll-to-top button up when scrolled past 10%
      if (window.scrollY > window.innerHeight * 0.1) {
        scrollToTopBtn.classList.add('footer-visible');
      } else {
        scrollToTopBtn.classList.remove('footer-visible');
      }
    });

    scrollToTopBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Contact modal
  const contactBtn = document.getElementById('brief-contact-btn');
  const headerContactBtn = document.getElementById('header-contact-btn');
  const contactModal = document.getElementById('brief-contact-modal');
  const contactBackdrop = document.getElementById('brief-contact-modal-backdrop');
  const contactClose = document.getElementById('brief-contact-modal-close');

  if (contactBtn && contactModal && contactBackdrop && contactClose) {
    function openContactModal() {
      contactModal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeContactModal() {
      contactModal.classList.remove('active');
      document.body.style.overflow = '';
    }

    contactBtn.addEventListener('click', openContactModal);
    if (headerContactBtn) headerContactBtn.addEventListener('click', openContactModal);
    contactBackdrop.addEventListener('click', closeContactModal);
    contactClose.addEventListener('click', closeContactModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && contactModal.classList.contains('active')) {
        closeContactModal();
      }
    });

    // Copy functionality
    const copyIcons = contactModal.querySelectorAll('.contact-modal-copy-icon');
    copyIcons.forEach(icon => {
      icon.addEventListener('click', async () => {
        const row = icon.closest('.contact-modal-row');
        const valueEl = row ? row.querySelector('.contact-modal-value') : null;
        const value = valueEl ? valueEl.textContent?.trim() : null;
        if (!value) return;

        try {
          await navigator.clipboard.writeText(value);
          const iconSpan = icon.querySelector('.material-symbols-outlined') || icon;
          const originalText = iconSpan.textContent;
          iconSpan.textContent = 'check';
          setTimeout(() => {
            iconSpan.textContent = originalText ?? 'content_copy';
          }, 1500);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  }
</script>

<style>
  .brief-overlay {
    position: relative;
    isolation: isolate;
    min-height: 100svh;
    padding: clamp(4.5rem, 7vw, 6rem) clamp(1rem, 3vw, 2.6rem) clamp(1rem, 3vw, 2.6rem);
    display: grid;
    place-items: start center;
  }

  .brief-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    background:
      radial-gradient(circle at 16% 0%, color-mix(in oklab, var(--tint) 28%, transparent), transparent 44%),
      rgba(7, 8, 10, 0.7);
    backdrop-filter: blur(8px);
    z-index: 1;
    cursor: default;
    pointer-events: none;
  }

  .brief-page {
    position: relative;
    z-index: 2;
    pointer-events: auto;
    width: min(1180px, 100%);
    border-radius: clamp(1rem, 2vw, 1.6rem);
    border: 1px solid color-mix(in oklab, var(--line) 74%, transparent);
    background: color-mix(in oklab, #090a0c 72%, var(--card) 28%);
    box-shadow:
      0 1.4rem 3.4rem rgba(0, 0, 0, 0.45),
      inset 0 0 0 1px color-mix(in oklab, var(--surface) 74%, transparent);
    padding: clamp(0.95rem, 2.8vw, 2rem);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 1rem;
    text-decoration: none;
    text-transform: none;
    font: 700 0.8rem/1 'Inter', sans-serif;
    letter-spacing: 0.03em;
    color: var(--muted);
  }

  .brief-hero {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1rem;
    background: var(--card);
    border-radius: 1.7rem;
    padding: clamp(1rem, 2.5vw, 1.8rem);
    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--card) 75%, #000 25%);
  }

  .group-pill {
    display: inline-flex;
    padding: 0.32rem 0.66rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font: 700 0.52rem/1 'Inter', sans-serif;
    margin: 0 0 0.65rem;
  }

  h1,
  h2 {
    margin: 0;
    font-family: 'Oswald', sans-serif;
    text-transform: uppercase;
    line-height: 0.9;
  }

  h1 {
    font-size: clamp(2.5rem, 8vw, 5.4rem);
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .tagline {
    margin: 0.75rem 0 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.82);
    font: 700 0.66rem/1.6 'Inter', sans-serif;
    max-width: 42ch;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .meta-grid {
    margin: 0;
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  .meta-grid div {
    border-radius: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: color-mix(in oklab, var(--surface) 74%, transparent);
    padding: 0.65rem 0.72rem;
  }

  .meta-grid dt {
    margin: 0 0 0.25rem;
    text-transform: none;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.62);
    font: 650 0.64rem/1 'Inter', sans-serif;
  }

  .meta-grid dd {
    margin: 0;
    font: 700 0.95rem/1.4 'Inter', sans-serif;
    text-transform: none;
    letter-spacing: 0.02em;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .metric-panel {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
    gap: 0.7rem;
  }

  .metric-card {
    margin: 0;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: color-mix(in oklab, var(--surface) 84%, transparent);
    padding: 0.75rem 0.85rem;
    min-width: 0;
    display: grid;
    gap: 0.28rem;
  }

  .metric-card-value {
    margin: 0;
    color: #ffffff;
    font: 700 1.78rem/1 'Oswald', sans-serif;
    letter-spacing: 0.01em;
    text-transform: none;
    overflow-wrap: anywhere;
  }

  .metric-card-label {
    margin: 0;
    text-transform: none;
    letter-spacing: 0.03em;
    color: rgba(255, 255, 255, 0.82);
    font: 650 0.82rem/1.45 'Inter', sans-serif;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .brief-body {
    margin-top: 1rem;
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 1rem;
  }

  .brief-body.no-media {
    grid-template-columns: 1fr;
  }

  .brief-copy,
  .brief-media {
    border-radius: 1.3rem;
    border: 1px solid var(--line);
    padding: clamp(1rem, 2.3vw, 1.4rem);
    background: color-mix(in oklab, var(--surface) 88%, transparent);
  }

  .brief-copy h2,
  .brief-media h2 {
    font-size: clamp(1.7rem, 3vw, 2.6rem);
    margin-bottom: 0.75rem;
  }

  .brief-copy p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .actions {
    margin-top: 1rem;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .actions a {
    text-decoration: none;
    border-radius: 999px;
    padding: 1rem 2rem;
    text-transform: none;
    font: 700 0.9rem/1 'Manrope', sans-serif;
    letter-spacing: 0.04em;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: transparent;
    color: inherit;
    display: inline-flex;
    align-items: center;
  }

  .actions a:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .actions .brief-contact-btn {
    text-decoration: none;
    border-radius: 999px;
    padding: 1rem 2rem;
    text-transform: none;
    font: 700 0.9rem/1 'Manrope', sans-serif;
